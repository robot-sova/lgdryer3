---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<div class="breadcrumbs-bar">
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs-list" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li class="bc-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/" class="bc-link" itemprop="item">
        <span itemprop="name">Home</span>
      </a>
      <meta itemprop="position" content="1" />
    </li>

    {items.map((item, index) => (
      <li class="bc-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <span class="bc-sep">&rsaquo;</span>
        {item.href ? (
          <a href={item.href} class="bc-link" itemprop="item">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span class="bc-current" itemprop="name">{item.label}</span>
        )}
        <meta itemprop="position" content={String(index + 2)} />
      </li>
    ))}
  </ol>
</nav>
</div>
