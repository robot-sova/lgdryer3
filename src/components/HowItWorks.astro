---
// Reusable "How it works" section — appears at the bottom of every layout.
const { appliance = 'dryer' } = Astro.props;
---

<section id="how-it-works" class="hw-section">
  <h2 class="hw-title">How it works</h2>
  <p class="hw-subtitle">From your first call to a working {appliance} — here's what to expect</p>

  <div class="hw-grid">
    <!-- CARD 1 — Book a visit -->
    <div class="hw-card">
      <div class="hw-step">01</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="5" width="18" height="16" rx="2"/>
          <path d="M16 3v4M8 3v4M3 11h18"/>
        </svg>
      </div>
      <h3 class="hw-card-title">Book a visit</h3>
      <p class="hw-card-desc">Call us, fill out the online form, or request a callback. Available 24/7 — we schedule a 2-hour arrival window at your convenience.</p>
      <span class="hw-tag">24/7 booking</span>
    </div>

    <!-- CARD 2 — Technician arrives -->
    <div class="hw-card">
      <div class="hw-step">02</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 16V6a1 1 0 0 1 1-1h11v11"/>
          <path d="M13 8h5l3 4v4h-2"/>
          <circle cx="6.5" cy="17.5" r="2.5"/>
          <circle cx="16.5" cy="17.5" r="2.5"/>
        </svg>
      </div>
      <h3 class="hw-card-title">Technician arrives</h3>
      <p class="hw-card-desc">You get a text 30 minutes before arrival. Our tech typically shows up in the first half of your 2-hour window.</p>
      <span class="hw-tag">On time, every time</span>
    </div>

    <!-- CARD 3 — Diagnosis (highlighted) -->
    <div class="hw-card hw-card-highlight">
      <div class="hw-step">03</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="7"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </div>
      <h3 class="hw-card-title">Diagnosis — $65</h3>
      <p class="hw-card-desc">Full inspection of your LG {appliance}. We identify the issue and give you a complete estimate — parts and labor — before touching anything.</p>
      <span class="hw-tag">Waived with repair</span>
    </div>

    <!-- CARD 4 — You approve (highlighted) -->
    <div class="hw-card hw-card-highlight">
      <div class="hw-step">04</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="9"/>
          <path d="M8 12l3 3 5-6"/>
        </svg>
      </div>
      <h3 class="hw-card-title">You approve the quote</h3>
      <p class="hw-card-desc">No surprises. Repair only begins after you agree to the estimate. If you decline, you pay only the $65 diagnostic fee — nothing more.</p>
      <span class="hw-tag">No pressure</span>
    </div>

    <!-- CARD 5 — Repair completed -->
    <div class="hw-card">
      <div class="hw-step">05</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5 2.5-2.5z"/>
        </svg>
      </div>
      <h3 class="hw-card-title">Repair completed</h3>
      <p class="hw-card-desc">We use OEM LG parts only — often cheaper than retail through our suppliers. 85% of repairs are done on the spot, same visit.</p>
      <span class="hw-tag">OEM parts · 1-yr warranty</span>
    </div>

    <!-- CARD 6 — Payment -->
    <div class="hw-card">
      <div class="hw-step">06</div>
      <div class="hw-icon-wrap">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="5" width="20" height="14" rx="2"/>
          <path d="M2 10h20M6 15h4"/>
        </svg>
      </div>
      <h3 class="hw-card-title">Payment — after demo</h3>
      <p class="hw-card-desc">Tech runs your {appliance} and shows the problem is fixed. Once you're satisfied, pay by card, cash, Zelle, Venmo, or PayPal.</p>
      <span class="hw-tag">Pay only when happy</span>
    </div>
  </div>

  <div class="hw-more">
    <a href="/how-it-works/" class="hw-more-link">See the full process explained →</a>
  </div>
</section>

<style>
  .hw-section {
    padding: 64px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hw-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    text-align: center;
    margin: 0 0 8px 0;
  }

  .hw-subtitle {
    font-size: 0.95rem;
    color: #8a9ab0;
    text-align: center;
    margin: 0 0 40px 0;
  }

  .hw-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .hw-card {
    background: #111111;
    border: 1px solid #1e2a3a;
    border-radius: 12px;
    padding: 24px 20px;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hw-card-highlight {
    border-left: 2px solid #1a6cf6;
  }

  .hw-step {
    position: absolute;
    top: 12px;
    left: 14px;
    font-size: 13px;
    color: #555555;
    letter-spacing: 0.05em;
  }

  .hw-icon-wrap {
    width: 48px;
    height: 48px;
    background: rgba(26, 108, 246, 0.12);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .hw-icon-wrap svg {
    width: 22px;
    height: 22px;
    stroke: #1a6cf6;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hw-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 8px 0;
  }

  .hw-card-desc {
    font-size: 0.85rem;
    color: #c8d0dc;
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }

  .hw-tag {
    display: inline-block;
    margin-top: 14px;
    font-size: 11px;
    font-weight: 500;
    color: #1a6cf6;
    background: rgba(26, 108, 246, 0.1);
    border-radius: 6px;
    padding: 4px 10px;
  }

  .hw-more {
    text-align: center;
    margin-top: 32px;
  }

  .hw-more-link {
    font-size: 0.9rem;
    color: #1a6cf6;
    text-decoration: none;
    border-bottom: 1px solid rgba(26, 108, 246, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s;
  }

  .hw-more-link:hover {
    border-color: #1a6cf6;
  }

  @media (max-width: 768px) {
    .hw-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
