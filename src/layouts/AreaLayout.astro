---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import HowItWorks from '../components/HowItWorks.astro';

interface Props {
  title: string;
  description: string;
  city: string;
  state?: string;
  county?: string;
  zipCodes?: string[];
  heroImg?: string;
  heroCaption?: string;
  areaImg?: string;
  areaImgCaption?: string;
  neighborhoods?: string[];
  featuredNeighborhoods?: string[];
  nearbyCities?: string[];
  testimonial?: { text: string; author: string; stars?: number };
  responseTime?: string;
}

const { title, description, city, state = 'CA', county, zipCodes = [], heroImg, heroCaption, areaImg, areaImgCaption, neighborhoods = [], featuredNeighborhoods = [], nearbyCities = [], testimonial, responseTime = '2–4 hours' } = Astro.props;

const cityToSlug: Record<string, string> = {
  'Agoura Hills': 'agoura-hills', 'Anaheim': 'anaheim', 'Bel Air': 'bel-air',
  'Beverly Hills': 'beverly-hills', 'Brentwood': 'brentwood', 'Burbank': 'burbank',
  'Calabasas': 'calabasas', 'Camarillo': 'camarillo', 'Costa Mesa': 'costa-mesa',
  'Culver City': 'culver-city', 'Dana Point': 'dana-point', 'Fullerton': 'fullerton',
  'Glendale': 'glendale', 'Huntington Beach': 'huntington-beach', 'Irvine': 'irvine',
  'Ladera Ranch': 'ladera-ranch', 'Laguna Beach': 'laguna-beach', 'Laguna Niguel': 'laguna-niguel',
  'Lake Forest': 'lake-forest', 'Long Beach': 'long-beach', 'Los Angeles': 'los-angeles',
  'Malibu': 'malibu', 'Manhattan Beach': 'manhattan-beach', 'Marina del Rey': 'marina-del-rey',
  'Mission Viejo': 'mission-viejo', 'Moorpark': 'moorpark', 'Newbury Park': 'newbury-park',
  'Newport Beach': 'newport-beach', 'Orange': 'orange-ca', 'Oxnard': 'oxnard',
  'Pacific Palisades': 'pacific-palisades', 'Pasadena': 'pasadena', 'Playa del Rey': 'playa-del-rey',
  'Rancho Santa Margarita': 'rancho-santa-margarita', 'Santa Monica': 'santa-monica',
  'Sherman Oaks': 'sherman-oaks', 'Simi Valley': 'simi-valley', 'Studio City': 'studio-city',
  'Thousand Oaks': 'thousand-oaks', 'Torrance': 'torrance', 'Tustin': 'tustin',
  'Ventura': 'ventura', 'West Hollywood': 'west-hollywood', 'Westlake Village': 'westlake-village',
  'Woodland Hills': 'woodland-hills', 'Yorba Linda': 'yorba-linda',
};
---

<Layout title={title} description={description} heroImg={heroImg}>
  <Breadcrumbs slot="breadcrumbs" items={[
    { label: "Areas", href: "/areas/" },
    { label: `${city}, CA` }
  ]} />

  <!-- HERO IMAGE -->
  <div style="max-width:1100px; margin:0 auto; padding:0 24px 16px;">
    {heroImg && (
      <div>
        <div style="width:100%; height:360px; overflow:hidden; border-radius:12px;">
          <img src={heroImg} alt={`LG Dryer Repair ${city}`} style="width:100%; height:100%; object-fit:cover; object-position:center top; display:block;" />
        </div>
        {heroCaption && <div class="article-hero-caption">{heroCaption}</div>}
      </div>
    )}
  </div>

  <div class="article-layout">
    <div class="article-body">
      <h1 class="area-page-h1">LG Dryer Repair in {city}{state ? `, ${state}` : ''}</h1>

      <!-- ZIP CODES + TRUST BADGES -->
      {zipCodes.length > 0 && (
        <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;">
          {zipCodes.map(zip => (
            <div style="background:#0d1a2e;border:1px solid #1a6cf6;border-radius:4px;padding:3px 9px;font-size:10px;color:#6ab0ff;">ZIP: {zip}</div>
          ))}
        </div>
      )}

      <div class="trust-badges">
        <div class="trust-badge">Same day service</div>
        <div class="trust-badge">{responseTime} response</div>
        <div class="trust-badge">Local technician</div>
        {county && <div class="trust-badge">{county} County</div>}
      </div>

      <slot name="intro" />

      <!-- AREA PHOTO -->
      {areaImg && (
        <div class="article-img-wrap" style="margin-bottom:0;">
          <img class="article-img" style="height:200px;" src={areaImg} alt={`${city} neighborhood`} />
          {areaImgCaption && <div class="article-img-caption">{areaImgCaption}</div>}
        </div>
      )}

      <!-- NEIGHBORHOODS -->
      {neighborhoods.length > 0 && (
        <div>
          <h2>Neighborhoods we serve in {city}</h2>
          <div class="neighborhood-grid">
            {neighborhoods.map(n => (
              <div class={`nh-chip ${featuredNeighborhoods.includes(n) ? 'featured' : ''}`}>{n}</div>
            ))}
          </div>
        </div>
      )}

      <slot />

      <!-- CALLBACK FORM -->
      <div class="callback-form-block" id="callback-form">
        <div class="callback-form-inner">
          <div class="callback-form-icon">📞</div>
          <h3 class="callback-form-title">Can't talk right now?</h3>
          <p class="callback-form-sub">Leave your number — we'll call you back within 30 minutes during business hours.</p>
          <form class="callback-form" id="callbackForm">
            <div class="callback-form-row">
              <input
                type="tel"
                id="callbackPhone"
                name="phone"
                placeholder="(XXX) XXX-XXXX"
                class="callback-input"
                required
              />
              <button type="submit" class="callback-btn">
                Call Me Back
              </button>
            </div>
            <p class="callback-form-note">Mon–Sat 8am–7pm · Sun 9am–5pm · No spam</p>
            <div class="callback-success" id="callbackSuccess" style="display:none">
              ✓ Got it! We'll call you back shortly.
            </div>
          </form>
        </div>
      </div>

      <!-- TESTIMONIAL -->
      {testimonial && (
        <div>
          <h2>What {city} clients say</h2>
          <div class="testimonial-block">
            <div class="t-stars">{'★'.repeat(testimonial.stars || 5)}</div>
            <div class="t-text">"{testimonial.text}"</div>
            <div class="t-author">— {testimonial.author}</div>
          </div>
        </div>
      )}
    </div>

    <!-- SIDEBAR -->
    <div class="article-sidebar">
      <div class="sidebar-cta">
        <div class="s-title">{city} Service</div>
        <div class="s-sub">{responseTime} · Same day</div>
        <a href="tel:(323)990-7550" class="s-phone">(323) 990-7550</a>
        <a href="/book/" class="s-btn">Book in {city}</a>
        <a href="#callback-form" class="sidebar-callback-link">
          Or request a call back ↓
        </a>
      </div>

      {nearbyCities.length > 0 && (
        <div class="sidebar-box">
          <div class="sb-title">Nearby Cities We Serve</div>
          <ul class="sidebar-checklist">
            {nearbyCities.map(c => {
              const slug = cityToSlug[c];
              return slug
                ? <li><a href={`/areas/lg-dryer-repair-${slug}/`}>{c}</a></li>
                : <li>{c}</li>;
            })}
          </ul>
        </div>
      )}

      <div class="sidebar-box">
        <div class="sb-title">Our Credentials</div>
        <ul class="sidebar-checklist">
          <li>CSLB Lic. #1138898</li>
          <li>BBB A+ rated</li>
          <li>85% first-visit fix</li>
          <li>OEM parts only</li>
        </ul>
      </div>
    </div>
  </div>

  <HowItWorks />

  <!-- MAP SECTION -->
  <div class="city-map-section">
    <div class="city-map-inner">
      <h2 class="map-title">Our Service Area in {city}</h2>
      <div class="map-wrapper">
        <iframe
          src={`https://www.openstreetmap.org/export/embed.html?bbox=-118.6%2C33.7%2C-117.9%2C34.2&layer=mapnik`}
          width="100%"
          height="400"
          style="border:0;"
          loading="lazy"
          title={`Service area map - ${city}, CA`}
        ></iframe>
      </div>
      <p class="map-note">We serve all neighborhoods in {city} and surrounding areas. Same-day service available.</p>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "LG Dryer Repair",
    "telephone": "(323) 990-7550",
    "email": "info@lgdryer.repair",
    "url": "https://lgdryer.repair",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": city,
      "addressRegion": "CA",
      "addressCountry": "US"
    },
    "areaServed": city + ", CA",
    "knowsAbout": ["LG dryer repair", "LG washer repair", "appliance repair"],
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "license",
      "name": "Bureau of Household Goods and Services #49573",
      "recognizedBy": {
        "@type": "GovernmentOrganization",
        "name": "California Department of Consumer Affairs"
      }
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    }
  })} />

  <meta name="city" content={city} />

  <script>
    const callbackForm = document.getElementById('callbackForm');
    if (callbackForm) {
      callbackForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const phone = (document.getElementById('callbackPhone') as HTMLInputElement).value;
        const cityMeta = document.querySelector('meta[name="city"]') as HTMLMetaElement | null;
        const city = cityMeta?.content || 'Unknown';
        const btn = callbackForm.querySelector('.callback-btn') as HTMLButtonElement;
        btn.textContent = 'Sending...';
        btn.disabled = true;
        try {
          await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: 'Call Back Request',
              phone: phone,
              message: `Call back request from ${city} area page`,
              email: 'callback@lgdryer.repair'
            })
          });
          (document.getElementById('callbackSuccess') as HTMLElement).style.display = 'block';
          (callbackForm.querySelector('.callback-form-row') as HTMLElement).style.display = 'none';
          (callbackForm.querySelector('.callback-form-note') as HTMLElement).style.display = 'none';
        } catch (err) {
          btn.textContent = 'Call Me Back';
          btn.disabled = false;
        }
      });
    }
  </script>
</Layout>

<style>
.area-page-h1 {
  font-size: 1.9rem;
  font-weight: 700;
  color: #ffffff;
  margin: 28px 0 20px;
  line-height: 1.2;
}

.sidebar-callback-link {
  display: block;
  text-align: center;
  margin-top: 10px;
  color: rgba(255,255,255,0.75);
  font-size: 0.85rem;
  text-decoration: underline;
  text-underline-offset: 3px;
  cursor: pointer;
  transition: color 0.2s;
}
.sidebar-callback-link:hover {
  color: #ffffff;
}

.callback-form-block {
  background: #111111;
  border: 1px solid #1e2a3a;
  border-radius: 12px;
  padding: 32px;
  margin: 40px 0;
  text-align: center;
}
.callback-form-icon {
  font-size: 2rem;
  margin-bottom: 12px;
}
.callback-form-title {
  font-size: 1.3rem;
  font-weight: 700;
  color: #ffffff;
  margin: 0 0 8px;
}
.callback-form-sub {
  color: #8a9ab0;
  font-size: 0.95rem;
  margin: 0 0 20px;
  line-height: 1.5;
}
.callback-form-row {
  display: flex;
  gap: 10px;
  max-width: 420px;
  margin: 0 auto 10px;
}
.callback-input {
  flex: 1;
  padding: 12px 16px;
  background: #0d1117;
  border: 1px solid #1e2a3a;
  border-radius: 6px;
  color: #ffffff;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.2s;
}
.callback-input:focus {
  border-color: #1a6cf6;
}
.callback-input::placeholder {
  color: #4a5a6a;
}
.callback-btn {
  padding: 12px 20px;
  background: #1a6cf6;
  color: #ffffff;
  border: none;
  border-radius: 6px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}
.callback-btn:hover {
  background: #1558d0;
}
.callback-form-note {
  color: #4a5a6a;
  font-size: 0.8rem;
  margin: 0;
}
.callback-success {
  margin-top: 16px;
  color: #4ade80;
  font-weight: 600;
  font-size: 1rem;
}
@media (max-width: 480px) {
  .callback-form-row {
    flex-direction: column;
  }
  .callback-form-block {
    padding: 24px 16px;
  }
}
</style>
