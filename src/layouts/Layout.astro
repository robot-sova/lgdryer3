---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'LG Dryer Repair Los Angeles | Same Day Service', description = 'Professional LG dryer repair in Los Angeles. Same-day service, certified technicians. Call (323) 990-7550.' } = Astro.props;

const repairLinks = [
  { slug: 'lg-dryer-heating-element-replacement', label: 'Heating Element Replacement' },
  { slug: 'lg-dryer-thermal-fuse-replacement', label: 'Thermal Fuse Replacement' },
  { slug: 'lg-dryer-drum-roller-replacement', label: 'Drum Roller Replacement' },
  { slug: 'lg-dryer-igniter-replacement', label: 'Igniter Replacement' },
  { slug: 'lg-dryer-motor-replacement', label: 'Motor Replacement' },
  { slug: 'lg-dryer-drum-bearing-replacement', label: 'Drum Bearing Replacement' },
  { slug: 'lg-dryer-belt-replacement', label: 'Belt Replacement' },
  { slug: 'lg-dryer-idler-pulley-replacement', label: 'Idler Pulley Replacement' },
  { slug: 'lg-dryer-gas-valve-replacement', label: 'Gas Valve Replacement' },
  { slug: 'lg-dryer-drum-replacement', label: 'Drum Replacement' },
