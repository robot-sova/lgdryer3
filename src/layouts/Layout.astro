  { slug: 'lg-dryer-drum-bearing-replacement-cost', label: 'Drum Bearing Replacement Cost' },
  { slug: 'lg-dryer-belt-replacement-cost', label: 'Belt Replacement Cost' },
  { slug: 'lg-dryer-drum-replacement-cost', label: 'Drum Replacement Cost' },
  { slug: 'install-dryer-vent-cost', label: 'Install Dryer Vent Cost' },
  { slug: 'lg-dryer-heating-element-replacement-cost', label: 'Heating Element Cost' },
  { slug: 'lg-dryer-thermal-fuse-replacement-cost', label: 'Thermal Fuse Cost' },
