  { slug: 'lg-dryer-repair-newport-beach', label: 'Newport Beach' },
  { slug: 'lg-dryer-repair-laguna-beach', label: 'Laguna Beach' },
  { slug: 'lg-dryer-repair-yorba-linda', label: 'Yorba Linda' },
  { slug: 'lg-dryer-repair-mission-viejo', label: 'Mission Viejo' },
  { slug: 'lg-dryer-repair-laguna-niguel', label: 'Laguna Niguel' },
  { slug: 'lg-dryer-repair-irvine', label: 'Irvine' },
];

