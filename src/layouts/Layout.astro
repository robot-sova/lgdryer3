---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://lgdryer.repair${Astro.url.pathname}`} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://lgdryer.repair${Astro.url.pathname}`} />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "LG Dryer Repair",
        "telephone": "(323) 990-7550",
        "email": "info@lgdryer.repair",
        "url": "https://lgdryer.repair",
        "logo": "https://lgdryer.repair/favicon.svg",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Los Angeles",
          "addressRegion": "CA",
          "addressCountry": "US"
        },
        "areaServed": ["Los Angeles County, CA", "Orange County, CA", "Ventura County, CA"],
        "knowsAbout": ["LG dryer repair", "LG washer repair", "appliance repair"],
        "hasCredential": {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "license",
          "name": "Bureau of Household Goods and Services #49573",
          "recognizedBy": {
            "@type": "GovernmentOrganization",
            "name": "California Department of Consumer Affairs"
          }
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
          "opens": "00:00",
          "closes": "23:59"
        }
      },
      {
        "@type": "WebSite",
        "name": "LG Dryer Repair",
        "url": "https://lgdryer.repair"
      }
    ]
  }
  </script>
</head>
<body>
  <header class="site-header">
  <nav class="navbar">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between">
      <a href="/" class="nav-logo"><span class="lg-badge">LG</span> lgdryer.repair</a>

      <div class="nav-links">
        <div class="nav-item">
          <button>Repair ▾</button>
          <div class="dropdown">
            {repairLinks.map(r => <a href={`/repairs/${r.slug}/`}>{r.label}</a>)}
          </div>
        </div>

        <div class="nav-item">
          <button>Symptoms ▾</button>
          <div class="dropdown">
            {symptomLinks.map(s => <a href={`/symptoms/${s.slug}/`}>{s.label}</a>)}
          </div>
        </div>

        <div class="nav-item">
          <button>Price List ▾</button>
          <div class="dropdown">
            {priceLinks.slice(0, 4).map(p => <a href={`/price-list/${p.slug}/`}>{p.label}</a>)}
            <a href="/price-list/lg-dryer-heating-element-replacement-cost/" style="border-top:1px solid rgba(255,255,255,0.06);margin-top:.25rem;padding-top:.65rem">View all prices →</a>
          </div>
        </div>

        <div class="nav-item">
          <button>Areas ▾</button>
          <div class="dropdown mega-menu">
            <div class="mega-menu-grid">
              <div>
                <h4>LA County</h4>
                {laCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
              </div>
              <div>
                <h4>Orange County</h4>
                {orangeCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
              </div>
              <div>
                <h4>Ventura County</h4>
                {venturaCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
              </div>
            </div>
          </div>
        </div>

        <a href="tel:3239907550" class="nav-cta btn">(323) 990-7550</a>
      </div>

      <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">☰</button>
    </div>
  </nav>
  <slot name="breadcrumbs" />
  </header>

  <!-- Mobile menu -->
  <div class="mobile-overlay" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="Close menu">✕</button>

    <div class="mobile-section">
      <h4>Repair Services</h4>
      {repairLinks.map(r => <a href={`/repairs/${r.slug}/`}>{r.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Symptoms</h4>
      {symptomLinks.map(s => <a href={`/symptoms/${s.slug}/`}>{s.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Price List</h4>
      {priceLinks.map(p => <a href={`/price-list/${p.slug}/`}>{p.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Service Areas</h4>
      {laCounty.slice(0,4).map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
      {orangeCounty.slice(0,2).map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
    </div>

    <a href="tel:3239907550" class="mobile-cta">(323) 990-7550</a>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <h4>Contact</h4>
          <p>Los Angeles, CA</p>
          <p><a href="tel:3239907550">(323) 990-7550</a></p>
          <p><a href="mailto:info@lgdryer.repair">info@lgdryer.repair</a></p>
        </div>
        <div>
          <h4>Hours</h4>
          <p>Monday – Saturday: 8am – 7pm</p>
          <p>Sunday: 9am – 5pm</p>
          <p>Emergency service available</p>
        </div>
        <div>
          <h4>Services</h4>
          <ul>
            {repairLinks.slice(0,5).map(r => <li><a href={`/repairs/${r.slug}/`}>{r.label}</a></li>)}
          </ul>
        </div>
        <div>
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/book/">Book a Visit</a></li>
            <li><a href="/sitemap.xml">Sitemap</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} lgdryer.repair — LG Dryer Repair Los Angeles. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.getElementById('mobileClose');

    function closeMenu() {
      mobileMenu?.classList.remove('active');
      if (hamburgerBtn) hamburgerBtn.innerHTML = '☰';
    }

    hamburgerBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('active');
      if (hamburgerBtn) hamburgerBtn.innerHTML = mobileMenu?.classList.contains('active') ? '✕' : '☰';
    });
    mobileClose?.addEventListener('click', closeMenu);
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) closeMenu();
    });
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
