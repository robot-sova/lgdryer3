  { slug: 'lg-dryer-door-lock-replacement-cost', label: 'Door Lock Replacement Cost' },
  { slug: 'dryer-and-washer-installation', label: 'Dryer & Washer Installation' },
  { slug: 'dryer-cleaning-service-cost', label: 'Cleaning Service Cost' },
];

const laCounty = [
  { slug: 'lg-dryer-repair-beverly-hills', label: 'Beverly Hills' },
  { slug: 'lg-dryer-repair-manhattan-beach', label: 'Manhattan Beach' },
  { slug: 'lg-dryer-repair-santa-monica', label: 'Santa Monica' },
  { slug: 'lg-dryer-repair-west-hollywood', label: 'West Hollywood' },
  { slug: 'lg-dryer-repair-pasadena', label: 'Pasadena' },
  { slug: 'lg-dryer-repair-burbank', label: 'Burbank' },
  { slug: 'lg-dryer-repair-glendale', label: 'Glendale' },
  { slug: 'lg-dryer-repair-long-beach', label: 'Long Beach' },
  { slug: 'lg-dryer-repair-torrance', label: 'Torrance' },
  { slug: 'lg-dryer-repair-calabasas', label: 'Calabasas' },
  { slug: 'lg-dryer-repair-malibu', label: 'Malibu' },
];

