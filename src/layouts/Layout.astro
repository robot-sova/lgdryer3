---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  {heroImg && <link rel="preload" as="image" href={heroImg} fetchpriority="high" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={`https://lgdryer.repair${Astro.url.pathname}`} />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://lgdryer.repair${Astro.url.pathname}`} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={resolvedOgImage} />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "name": "LG Dryer Repair",
        "telephone": "(323) 990-7550",
        "email": "info@lgdryer.repair",
        "url": "https://lgdryer.repair",
        "logo": "https://lgdryer.repair/favicon.svg",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Los Angeles",
          "addressRegion": "CA",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 34.0522,
          "longitude": -118.2437
        },
        "areaServed": ["Los Angeles County, CA", "Orange County, CA", "Ventura County, CA"],
        "knowsAbout": ["LG dryer repair", "LG washer repair", "appliance repair"],
        "hasCredential": {
          "@type": "EducationalOccupationalCredential",
          "credentialCategory": "license",
          "name": "Bureau of Household Goods and Services #49573",
          "recognizedBy": {
            "@type": "GovernmentOrganization",
            "name": "California Department of Consumer Affairs"
          }
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
          "opens": "08:00",
          "closes": "20:00"
        }
      },
      {
        "@type": "WebSite",
        "name": "LG Dryer Repair",
        "url": "https://lgdryer.repair"
      }
    ]
  }
  </script>
</head>
<body>
  <header class="site-header">
  <nav class="navbar">
    <div class="container" style="display:flex;align-items:center;justify-content:space-between">
      <a href="/" class="nav-logo"><span class="lg-badge">LG</span> lgdryer.repair</a>

      <div class="nav-links">
        <div class="nav-item">
          <button>Repair ▾</button>
          <div class="dropdown">
            {repairLinks.map(r => <a href={`/repairs/${r.slug}/`}>{r.label}</a>)}
            <div class="nav-divider"></div>
            <a href="/how-it-works/" class="nav-link-secondary">How it works →</a>
            <a href="/property-managers/" class="nav-link-secondary">For property managers →</a>
            <a href="/help/lg-dryer-parts/" class="nav-link-secondary">Parts diagram →</a>
          </div>
        </div>

        <div class="nav-item">
          <button>Symptoms ▾</button>
          <div class="dropdown">
            {symptomLinks.map(s => <a href={`/symptoms/${s.slug}/`}>{s.label}</a>)}
          </div>
        </div>

        <div class="nav-item">
          <button>Price List ▾</button>
          <div class="dropdown dropdown-price">
            <div class="price-grid">
              {priceLinks.map(p => (
                <a href={`/price-list/${p.slug}/`} class="price-link">
                  <span class="price-label">{p.label}</span>
                  <span class="price-range">{p.price}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="nav-item">
          <button>Areas ▾</button>
          <div class="dropdown dropdown-areas">
            <div class="areas-mega-menu">
              <div class="county-section">
                <div class="county-title">LA COUNTY</div>
                <div class="county-cities">
                  {laCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
                </div>
              </div>
              <div class="county-section">
                <div class="county-title">ORANGE COUNTY</div>
                <div class="county-cities">
                  {orangeCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
                </div>
              </div>
              <div class="county-section">
                <div class="county-title">VENTURA COUNTY</div>
                <div class="county-cities">
                  {venturaCounty.map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
                </div>
              </div>
            </div>
          </div>
        </div>

        <a href="/about/" class="nav-link-plain">About</a>
        <a href="tel:3239907550" class="nav-cta btn">(323) 990-7550</a>
      </div>

      <button class="hamburger" id="hamburgerBtn" aria-label="Open menu">☰</button>
    </div>
  </nav>
  <slot name="breadcrumbs" />
  </header>

  <!-- Mobile menu -->
  <div class="mobile-overlay" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="Close menu">✕</button>

    <div class="mobile-section">
      <h4>Repair Services</h4>
      {repairLinks.map(r => <a href={`/repairs/${r.slug}/`}>{r.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Symptoms</h4>
      {symptomLinks.map(s => <a href={`/symptoms/${s.slug}/`}>{s.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Price List</h4>
      {priceLinks.map(p => <a href={`/price-list/${p.slug}/`}>{p.label}</a>)}
    </div>
    <div class="mobile-section">
      <h4>Service Areas</h4>
      {laCounty.slice(0,4).map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
      {orangeCounty.slice(0,2).map(c => <a href={`/areas/${c.slug}/`}>{c.label}</a>)}
    </div>

    <div class="mobile-section">
      <h4>Help</h4>
      <a href="/help/lg-dryer-parts/">Parts Diagram</a>
      <a href="/help/lg-dryer-fire-hazard/">Fire Hazard & Prevention</a>
    </div>

    <a href="tel:3239907550" class="mobile-cta">(323) 990-7550</a>
  </div>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div>
          <h4>Contact</h4>
          <p>Los Angeles, CA</p>
          <p><a href="tel:3239907550">(323) 990-7550</a></p>
          <p><a href="mailto:info@lgdryer.repair">info@lgdryer.repair</a></p>
          <p class="footer-tagline">
            LG Dryer Repair is a specialized appliance service company
            providing expert repair and installation of LG dryers and washers
            across Los Angeles County, Orange County, and Ventura County.
            Same-day service, OEM parts, 1-year warranty.
          </p>
        </div>
        <div>
          <h4>Hours</h4>
          <p>Monday – Saturday: 8:00 AM – 8:00 PM</p>
          <p>Sunday: Closed</p>
          <p>Online booking & phone available 24/7</p>
        </div>
        <div>
          <h4>Services</h4>
          <ul>
            {repairLinks.slice(0,5).map(r => <li><a href={`/repairs/${r.slug}/`}>{r.label}</a></li>)}
          </ul>
        </div>
        <div>
          <h4>Owner Tips</h4>
          <ul>
            <li><a href="/help/lg-dryer-tips/">Maintenance Guide</a></li>
            <li><a href="/help/lg-dryer-fire-hazard/">Fire Safety</a></li>
            <li><a href="/help/lg-dryer-parts/">Parts Guide</a></li>
            <li><a href="/help/">All Guides →</a></li>
          </ul>
        </div>
        <div>
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/book/">Book a Visit</a></li>
            <li><a href="/how-it-works/">How it works</a></li>
            <li><a href="/property-managers/">For property managers</a></li>
            <li><a href="/about/">About Us</a></li>
            <li><a href="/careers/">Careers</a></li>
            <li><a href="/sitemap.xml">Sitemap</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} lgdryer.repair — LG Dryer Repair Los Angeles. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileClose = document.getElementById('mobileClose');

    function closeMenu() {
      mobileMenu?.classList.remove('active');
      if (hamburgerBtn) hamburgerBtn.innerHTML = '☰';
    }

    hamburgerBtn?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('active');
      if (hamburgerBtn) hamburgerBtn.innerHTML = mobileMenu?.classList.contains('active') ? '✕' : '☰';
    });
    mobileClose?.addEventListener('click', closeMenu);
    mobileMenu?.addEventListener('click', (e) => {
      if (e.target === mobileMenu) closeMenu();
    });
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  .dropdown-price {
    width: 540px;
    position: fixed;
    top: 56px;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-item:hover .dropdown-price,
  .nav-item:focus-within .dropdown-price {
    transform: translateX(-50%);
  }

  .price-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    padding: 8px;
  }

  .price-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 10px;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
    gap: 8px;
  }

  .price-link:hover {
    background: rgba(26, 108, 246, 0.12);
  }

  .price-label {
    color: #c8d0dc;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .price-link:hover .price-label {
    color: #ffffff;
  }

  .price-range {
    color: #1a6cf6;
    font-size: 0.8rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .dropdown-areas {
    width: 600px;
    position: fixed;
    top: 56px;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-item:hover .dropdown-areas,
  .nav-item:focus-within .dropdown-areas {
    transform: translateX(-50%);
  }

  .areas-mega-menu {
    padding: 20px 24px;
    min-width: 600px;
  }

  .county-section {
    margin-bottom: 20px;
  }

  .county-section:last-child {
    margin-bottom: 0;
  }

  .county-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #1a6cf6;
    text-transform: uppercase;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #1e2a3a;
  }

  .county-cities {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px 12px;
  }

  .county-cities a {
    font-size: 13px;
    color: #c8d0dc;
    text-decoration: none;
    padding: 3px 0;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .county-cities a:hover {
    color: #1a6cf6;
  }

  .nav-divider {
    height: 1px;
    background: #1e2a3a;
    margin: 6px 8px;
  }

  .nav-link-secondary {
    font-size: 0.85rem;
    color: #8a9ab0;
  }

  .nav-link-secondary:hover {
    color: #1a6cf6;
  }

  .footer-tagline {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    margin-top: 8px;
    max-width: 260px;
  }
</style>
