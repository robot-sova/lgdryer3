---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AIDiagnosticCTA from '../components/AIDiagnosticCTA.astro';
import HowItWorks from '../components/HowItWorks.astro';

interface Props {
  title: string;
  description: string;
  h1?: string;
  heroImg?: string;
  heroAlt?: string;
  heroCaption?: string;
  partPhoto?: string;
  partPhotoAlt?: string;
  partPhotoCaption?: string;
  partPhotoLabel?: string;
  beforeAfterPhotos?: Array<{src: string, alt: string, caption: string}>;
  cost?: string;
  price_min?: number;
  price_max?: number;
}

const { title, description, h1, heroImg, heroAlt, heroCaption, partPhoto, partPhotoAlt, partPhotoCaption, partPhotoLabel, beforeAfterPhotos, cost, price_min = 149, price_max = 399 } = Astro.props;
---

<Layout title={title} description={description} heroImg={heroImg} ogImage={heroImg}>
  <Breadcrumbs slot="breadcrumbs" items={[
    { label: "Repairs", href: "/repairs/" },
    { label: title.split("|")[0].split("—")[0].trim() }
  ]} />

  {h1 && (
    <h1 class="repair-h1">{h1}</h1>
  )}

  <!-- HERO IMAGE -->
  <div style="max-width:1100px; margin:0 auto; padding:0 24px 16px;">
    {heroImg && (
      <div>
        <div style="width:100%; height:360px; overflow:hidden; border-radius:12px;">
          <img src={heroImg} alt={heroAlt || 'LG Dryer Repair Los Angeles'} style="width:100%; height:100%; object-fit:cover; object-position:center top; display:block;" />
        </div>
        {heroCaption && <div class="article-hero-caption">{heroCaption}</div>}
      </div>
    )}
  </div>

  <!-- 2-COLUMN LAYOUT -->
  <div class="article-layout">
    <div class="article-body">
      <slot name="before-part-photo" />

      <!-- PART PHOTO (inline) -->
      {partPhoto && (
        <div class="article-img-wrap">
          {partPhotoLabel && <div class="article-img-label">{partPhotoLabel}</div>}
          <img class="article-img" src={partPhoto} alt={partPhotoAlt || 'LG dryer part'} />
          {partPhotoCaption && <div class="article-img-caption">{partPhotoCaption}</div>}
        </div>
      )}

      <slot />

      <!-- BEFORE/AFTER GRID -->
      {beforeAfterPhotos && beforeAfterPhotos.length > 0 && (
        <div>
          <h2>Before & after</h2>
          <div class="article-img-grid-2">
            {beforeAfterPhotos.map(photo => (
              <div class="grid-item">
                <img src={photo.src} alt={photo.alt} />
                <div class="grid-cap">{photo.caption}</div>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- SIDEBAR -->
    <div class="article-sidebar">
      <div class="sidebar-cta">
        <div class="s-title">Same Day Service</div>
        <div class="s-sub">Mon–Sat 8am–8pm · OEM parts</div>
        <a href="tel:(323)990-7550" class="s-phone">(323) 990-7550</a>
        <a href="/book/" class="s-btn">Book Online</a>
      </div>

      {cost && (
        <div class="sidebar-box">
          <div class="sb-title">Typical Cost</div>
          <div class="sb-price">{cost}</div>
          <div class="sb-note">Parts + labor · $65 diagnostic<br/>fee waived with repair</div>
        </div>
      )}

      <div class="sidebar-box">
        <div class="sb-title">Why Us</div>
        <ul class="sidebar-checklist">
          <li>85% first-visit fix rate</li>
          <li>Bureau of Household Goods and Services #49573</li>
          <li>BBB A+ rated</li>
          <li>OEM parts only</li>
          <li>1-year warranty</li>
        </ul>
      </div>

      <div class="sidebar-box">
        <div class="sb-title">Pricing</div>
        <ul class="sidebar-checklist">
          <li><a href="/price-list/lg-dryer-repair-cost/">LG Dryer Repair Cost</a></li>
          <li><a href="/price-list/lg-dryer-heating-element-replacement-cost/">Heating Element Cost</a></li>
          <li><a href="/price-list/lg-dryer-thermal-fuse-replacement-cost/">Thermal Fuse Cost</a></li>
          <li><a href="/price-list/lg-dryer-drum-roller-replacement-cost/">Drum Roller Cost</a></li>
        </ul>
      </div>

      <div class="sidebar-ai-diag">
        <AIDiagnosticCTA />
      </div>
    </div>
  </div>

  <!-- SERVICE AREAS -->
  <div class="repair-areas">
    <h3>Service Areas</h3>
    <div class="repair-areas-links">
      <a href="/areas/lg-dryer-repair-los-angeles/">Los Angeles</a>
      <a href="/areas/lg-dryer-repair-pasadena/">Pasadena</a>
      <a href="/areas/lg-dryer-repair-glendale/">Glendale</a>
      <a href="/areas/lg-dryer-repair-burbank/">Burbank</a>
      <a href="/areas/lg-dryer-repair-long-beach/">Long Beach</a>
      <a href="/areas/lg-dryer-repair-irvine/">Irvine</a>
      <a href="/areas/" class="repair-areas-all">All 45+ cities →</a>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": title,
        "description": description,
        "provider": { "@id": "https://lgdryer.repair/#business" },
        "areaServed": ["Los Angeles County, CA", "Orange County, CA", "Ventura County, CA"],
        "offers": {
          "@type": "Offer",
          "priceCurrency": "USD",
          "priceSpecification": {
            "@type": "PriceSpecification",
            "minPrice": price_min,
            "maxPrice": price_max,
            "priceCurrency": "USD"
          }
        }
      }
    ]
  })} />

  <HowItWorks />
</Layout>

<style>
.repair-h1 {
  font-size: 1.9rem;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  margin: 28px auto 20px auto;
  max-width: 1100px;
  padding: 0 24px;
}

/* AI Diagnostics in sidebar — compact override */
.sidebar-ai-diag {
  margin-top: 16px;
}
.sidebar-ai-diag :global(.ai-diag-block) {
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  margin: 0;
  border-radius: 10px;
}
.sidebar-ai-diag :global(.ai-diag-icon) {
  width: 36px;
  height: 36px;
}
.sidebar-ai-diag :global(.ai-diag-title) {
  font-size: 0.95rem;
}
.sidebar-ai-diag :global(.ai-diag-text) {
  font-size: 0.9rem;
  margin-bottom: 12px;
}
.sidebar-ai-diag :global(.ai-diag-btn) {
  font-size: 0.9rem;
  padding: 8px 14px;
  width: 100%;
  justify-content: center;
}

.repair-areas {
  max-width: 1100px;
  margin: 0 auto;
  padding: 32px 24px 0;
}
.repair-areas h3 {
  font-size: 1rem;
  font-weight: 600;
  color: #8a9ab0;
  margin: 0 0 12px;
}
.repair-areas-links {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 16px;
}
.repair-areas-links a {
  color: #c8d0dc;
  text-decoration: none;
  font-size: 0.9rem;
  transition: color 0.2s;
}
.repair-areas-links a:hover {
  color: #1a6cf6;
}
.repair-areas-all {
  color: #1a6cf6 !important;
}
</style>
