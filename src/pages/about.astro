---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout title="About Same Day LG Dryer Repair Los Angeles | Roman Abysov" description="Meet the team behind Same Day LG Dryer Repair in Los Angeles. Bureau of Household Goods and Services #49573, BBB accredited, 1500+ repairs completed since 2022. Roman Abysov, founder."
  hubHeroImg="/images/hubs/about-hero.webp"
  hubHeroAlt="LG Dryer Repair technician with a service van in a California driveway">
  <Breadcrumbs slot="breadcrumbs" items={[{ label: "About" }]} />

  <div class="about-page">
    <h1>About Same Day LG Dryer Repair</h1>

    <p class="about-intro">Same Day LG Dryer Repair is a specialized appliance service focused exclusively on LG dryers and washers across Los Angeles County, Orange County, and Ventura County. Founded in 2022, we've completed over 1,500 repairs — same-day service, OEM parts only, every job backed by warranty.</p>

    <!-- FOUNDER -->
    <section class="about-section">
      <h2>Roman Abysov — Founder & Lead Technician</h2>
      <div class="about-founder">
        <img src="/images/about/roman-lg-dryer-repair-los-angeles.webp"
             alt="Roman Abysov — LG Dryer Repair Technician Los Angeles"
             width="400" height="500"
             loading="eager"
             style="width:100%; max-width:400px; border-radius:12px; display:block;" />
        <div class="about-founder-text">
          <p>Roman founded the company in 2022 with a simple idea: specialize in one brand and know it better than anyone. That narrow focus on LG appliances means we know every model inside out — from older DLEX and DLE series to the latest ThinQ dryers with Wi-Fi diagnostics and smart error reporting.</p>
          <p>Over three years and 1,500+ repairs across Greater Los Angeles, that specialization has translated into an 85% first-visit fix rate, faster diagnostics, and lower costs for customers. When you only work on one brand, you carry the right parts, you've seen every failure mode, and you don't waste time guessing.</p>
        </div>
      </div>
    </section>

    <!-- LICENSES -->
    <section class="about-section">
      <h2>Licensed, Insured & Accredited</h2>
      <div class="about-credentials">
        <div class="credential-card">
          <div class="credential-label">Bureau of Household Goods and Services</div>
          <div class="credential-value">#49573</div>
          <div class="credential-note">California Department of Consumer Affairs</div>
        </div>
        <div class="credential-card">
          <div class="credential-label">BBB Accredited</div>
          <div class="credential-value">A+ Rating</div>
          <div class="credential-note">Better Business Bureau</div>
        </div>
        <div class="credential-card">
          <div class="credential-label">Insurance</div>
          <div class="credential-value">Fully Insured</div>
          <div class="credential-note">General liability & workers' comp</div>
        </div>
      </div>
    </section>

    <!-- WARRANTY -->
    <section class="about-section">
      <h2>Our Warranty</h2>
      <ul class="about-list">
        <li><strong>Standard repair:</strong> 90-day warranty on parts and labor</li>
        <li><strong>Full unit rebuild:</strong> 12-month warranty</li>
        <li><strong>OEM parts only</strong> — no aftermarket substitutes, ever</li>
      </ul>
    </section>

    <!-- SERVICE AREA -->
    <section class="about-section">
      <h2>Where We Work</h2>
      <div class="about-areas">
        <div>
          <h3>LA County</h3>
          <ul>
            <li><a href="/areas/lg-dryer-repair-los-angeles/">Los Angeles</a></li>
            <li><a href="/areas/lg-dryer-repair-pasadena/">Pasadena</a></li>
            <li><a href="/areas/lg-dryer-repair-glendale/">Glendale</a></li>
            <li><a href="/areas/lg-dryer-repair-burbank/">Burbank</a></li>
            <li><a href="/areas/lg-dryer-repair-santa-monica/">Santa Monica</a></li>
            <li><a href="/areas/lg-dryer-repair-malibu/">Malibu</a></li>
            <li><a href="/areas/lg-dryer-repair-beverly-hills/">Beverly Hills</a></li>
            <li><a href="/areas/lg-dryer-repair-culver-city/">Culver City</a></li>
          </ul>
        </div>
        <div>
          <h3>Orange County</h3>
          <ul>
            <li><a href="/areas/lg-dryer-repair-irvine/">Irvine</a></li>
            <li><a href="/areas/lg-dryer-repair-anaheim/">Anaheim</a></li>
            <li><a href="/areas/lg-dryer-repair-huntington-beach/">Huntington Beach</a></li>
            <li><a href="/areas/lg-dryer-repair-newport-beach/">Newport Beach</a></li>
            <li><a href="/areas/lg-dryer-repair-laguna-beach/">Laguna Beach</a></li>
            <li><a href="/areas/lg-dryer-repair-mission-viejo/">Mission Viejo</a></li>
          </ul>
        </div>
        <div>
          <h3>Ventura County</h3>
          <ul>
            <li><a href="/areas/lg-dryer-repair-thousand-oaks/">Thousand Oaks</a></li>
            <li><a href="/areas/lg-dryer-repair-simi-valley/">Simi Valley</a></li>
            <li><a href="/areas/lg-dryer-repair-camarillo/">Camarillo</a></li>
            <li><a href="/areas/lg-dryer-repair-moorpark/">Moorpark</a></li>
            <li><a href="/areas/lg-dryer-repair-ventura/">Ventura</a></li>
            <li><a href="/areas/lg-dryer-repair-newbury-park/">Newbury Park</a></li>
          </ul>
        </div>
      </div>
      <p class="about-areas-more"><a href="/areas/">See all 45+ service areas →</a></p>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <h2>Ready to book a repair?</h2>
      <p>Call (323) 990-7550 or book online. Same-day service available.</p>
      <p class="about-address">Office: 155 N Lake Ave #800, Pasadena, CA 91101<br/>We come to you — no walk-ins.</p>
      <div class="about-cta-buttons">
        <a href="tel:3239907550" class="btn btn-primary">Call Now</a>
        <a href="/book/" class="btn btn-outline">Book Online</a>
      </div>
    </section>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Roman Abysov",
    "jobTitle": "Founder & Lead Technician",
    "worksFor": {
      "@type": "LocalBusiness",
      "name": "Same Day LG Dryer Repair",
      "telephone": "(323) 990-7550",
      "url": "https://lgdryer.repair"
    }
  }
  </script>
</Layout>

<style>
  .about-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 24px 64px;
  }
  .about-page h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 20px;
  }
  .about-intro {
    font-size: 1.05rem;
    color: #c8d0dc;
    line-height: 1.7;
    margin: 0 0 40px;
  }
  .about-section {
    margin-bottom: 40px;
  }
  .about-section h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 16px;
  }
  .about-section h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 10px;
  }
  .about-section p {
    color: #c8d0dc;
    line-height: 1.7;
    margin: 0 0 12px;
  }

  /* Founder */
  .about-founder {
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }
  .about-photo-placeholder {
    flex-shrink: 0;
    width: 160px;
    height: 160px;
    background: #111;
    border: 1px solid #1e2a3a;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a5a6a;
    font-size: 0.85rem;
  }

  /* Credentials */
  .about-credentials {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .credential-card {
    background: #111;
    border: 1px solid #1e2a3a;
    border-radius: 10px;
    padding: 20px;
  }
  .credential-label {
    font-size: 0.8rem;
    color: #8a9ab0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .credential-value {
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }
  .credential-value a {
    color: #1a6cf6;
    text-decoration: none;
  }
  .credential-value a:hover {
    text-decoration: underline;
  }
  .credential-note {
    font-size: 0.82rem;
    color: #6a7a8a;
  }

  /* List */
  .about-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-list li {
    color: #c8d0dc;
    line-height: 1.7;
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
  }
  .about-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #1a6cf6;
    font-weight: 700;
  }

  /* Areas */
  .about-areas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .about-areas ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-areas li {
    margin-bottom: 6px;
  }
  .about-areas a {
    color: #c8d0dc;
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s;
  }
  .about-areas a:hover {
    color: #1a6cf6;
  }
  .about-areas-more {
    margin-top: 12px;
  }
  .about-areas-more a {
    color: #1a6cf6;
    text-decoration: none;
    font-size: 0.9rem;
  }

  /* CTA */
  .about-cta {
    background: #111;
    border: 1px solid #1e2a3a;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
  }
  .about-cta h2 {
    font-size: 1.3rem;
    color: #fff;
    margin: 0 0 8px;
  }
  .about-cta p {
    color: #8a9ab0;
    margin: 0 0 20px;
  }
  .about-address {
    font-size: 0.9rem;
    color: #6a7a8a !important;
  }
  .about-cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
  }
  .btn-outline {
    background: transparent;
    border: 1px solid #1a6cf6;
    color: #1a6cf6;
    padding: 10px 24px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-outline:hover {
    background: rgba(26, 108, 246, 0.1);
  }

  @media (max-width: 768px) {
    .about-founder {
      flex-direction: column;
    }
    .about-credentials {
      grid-template-columns: 1fr;
    }
    .about-areas {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .about-cta-buttons {
      flex-direction: column;
    }
  }
</style>
