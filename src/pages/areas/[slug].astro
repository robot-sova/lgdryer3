---
import Layout from '../../layouts/Layout.astro';
import { areas } from '../../data/areas';

export function getStaticPaths() {
  return Object.keys(areas).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const area = areas[slug!];
---

<Layout title={`LG Dryer Repair ${area.city} | Same Day Service`}>
  <section class="page-hero">
    <div class="container">
      <span class="badge badge-blue">{area.county}</span>
      <h1>LG Dryer Repair in {area.city}</h1>
      <p class="subtitle">Same-day LG dryer repair service in {area.city} and surrounding areas</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:800px">
      <p style="font-size:1.1rem;color:rgba(255,255,255,0.7);line-height:1.8;margin-bottom:2rem">
        Looking for professional LG dryer repair in {area.city}? Our certified technicians provide same-day service throughout {area.county}, including {area.city} and neighboring communities. We repair all LG dryer models — gas and electric — with genuine OEM parts and a 90-day warranty.
      </p>

      <h2 class="section-title">Our Services in {area.city}</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1rem;margin-bottom:3rem">
        <div class="glass" style="padding:1.25rem">
          <h3 style="font-size:1rem;margin-bottom:.35rem">Heating Repairs</h3>
          <p class="text-secondary" style="font-size:.875rem">Heating elements, thermal fuses, igniters, gas valves</p>
        </div>
        <div class="glass" style="padding:1.25rem">
          <h3 style="font-size:1rem;margin-bottom:.35rem">Mechanical Repairs</h3>
          <p class="text-secondary" style="font-size:.875rem">Belts, drums, rollers, bearings, motors, pulleys</p>
        </div>
        <div class="glass" style="padding:1.25rem">
          <h3 style="font-size:1rem;margin-bottom:.35rem">Maintenance</h3>
          <p class="text-secondary" style="font-size:.875rem">Vent cleaning, full cleaning, annual maintenance</p>
        </div>
      </div>

      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-item">
        <h3>Do you offer same-day service in {area.city}?</h3>
        <p>Yes. We have technicians throughout {area.county} and can usually schedule same-day service in {area.city} for calls received before 2:00 PM.</p>
      </div>
      <div class="faq-item">
        <h3>What LG dryer models do you repair in {area.city}?</h3>
        <p>We repair all LG dryer models including DLEX, DLGX, DLE, DLG, and Signature series. Gas and electric, front-load and top-load.</p>
      </div>
      <div class="faq-item">
        <h3>How much does LG dryer repair cost in {area.city}?</h3>
        <p>Repair costs depend on the issue. Our diagnostic fee is $89 (waived with repair). Most common repairs range from $100–$350. We provide an exact quote before starting any work.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>LG Dryer Repair in {area.city}</h2>
      <p>Same-day service available. Call now or book online.</p>
      <div class="cta-buttons">
        <a href="tel:3239907550" class="btn btn-primary btn-lg">Call (323) 990-7550</a>
        <a href="/book" class="btn btn-secondary btn-lg">Book Online</a>
      </div>
    </div>
  </section>
</Layout>
