<script is:inline>
const PD={
  belt:{n:1,c:'#1a6cf6',cat:'mechanical',nm:'Drive belt',pr:'$260–320',sym:'Drum not spinning — motor still hums',t:'60–75 min',u:'/repairs/lg-dryer-belt-replacement/'},
  heating:{n:2,c:'#e24b4a',cat:'heating',nm:'Heating element',pr:'$320–380',sym:'No heat — clothes damp after cycle',t:'45–60 min',u:'/repairs/lg-dryer-heating-element-replacement/'},
  fuse:{n:3,c:'#e24b4a',cat:'heating',nm:'Thermal fuse',pr:'$280–350',sym:'No heat or won\'t start',t:'30–45 min',u:'/repairs/lg-dryer-thermal-fuse-replacement/'},
  rollers:{n:4,c:'#1a6cf6',cat:'mechanical',nm:'Drum rollers',pr:'$280–350',sym:'Grinding or thumping while running',t:'60–75 min',u:'/repairs/lg-dryer-drum-roller-replacement/'},
  pulley:{n:5,c:'#1a6cf6',cat:'mechanical',nm:'Idler pulley',pr:'$200–260',sym:'Squealing or squeaking at startup',t:'60–75 min',u:'/repairs/lg-dryer-idler-pulley-replacement/'},
  motor:{n:6,c:'#7f77dd',cat:'drive',nm:'Drive motor',pr:'$380–480',sym:'Drum won\'t spin at all',t:'90–120 min',u:'/repairs/lg-dryer-motor-replacement/'},
  gas:{n:7,c:'#e24b4a',cat:'heating',nm:'Gas valve',pr:'$280–450',sym:'No heat — gas models only',t:'60–90 min',u:'/repairs/lg-dryer-gas-valve-replacement/'},
  seal:{n:8,c:'#888780',cat:'housing',nm:'Drum felt seal',pr:'$280–350',sym:'Thumping, clothes catching at front',t:'60–75 min',u:'/repairs/lg-dryer-drum-bearing-replacement/'},
  latch:{n:9,c:'#888780',cat:'housing',nm:'Door latch',pr:'$150–220',sym:'Dryer won\'t start — door not sensing',t:'20–30 min',u:'/symptoms/lg-dryer-not-starting/'},
};
let pCur=null,pCat='all';
function partsRenderSidebar(){
  const sb=document.getElementById('parts-sidebar');
  sb.innerHTML=Object.entries(PD).map(([id,p])=>{
    const show=pCat==='all'||p.cat===pCat;
    return '<div class="part-card'+(pCur===id?' on':'')+(show?'':' dim')+'" id="ppc-'+id+'" onclick="partsSel(\''+id+'\')"><div class="pc-top"><span class="pc-num" style="background:'+p.c+'">'+p.n+'</span><span class="pc-nm">'+p.nm+'</span></div><div class="pc-pr" style="color:'+p.c+'">'+p.pr+'</div><div class="pc-sym">'+p.sym+'</div></div>';
  }).join('');
}
function partsSel(id){
  pCur=id;
  const p=PD[id];
  document.querySelectorAll('.hs').forEach(h=>h.classList.remove('on'));
  document.getElementById('phs-'+id).classList.add('on');
  const bar=document.getElementById('parts-infobar');
  bar.classList.add('on');
  document.getElementById('pib-nm').textContent=p.nm;
  document.getElementById('pib-nm').style.color=p.c;
  document.getElementById('pib-pr').textContent=p.pr+' · '+p.t+' on-site';
  document.getElementById('pib-pr').style.color=p.c;
  document.getElementById('pib-sym').textContent=p.sym;
  document.getElementById('pib-link').href=p.u;
  partsRenderSidebar();
  const card=document.getElementById('ppc-'+id);
  if(card) card.scrollIntoView({block:'nearest',behavior:'smooth'});
}
function partsFilter(cat,btn){
  pCat=cat;
  document.querySelectorAll('.parts-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  Object.keys(PD).forEach(id=>{
    const show=cat==='all'||PD[id].cat===cat;
    const op=show?'1':'0.08';
    ['ppd-','pcl-','phs-'].forEach(pre=>{
      const el=document.getElementById(pre+id);
      if(el) el.style.opacity=op;
    });
  });
  partsRenderSidebar();
}
partsRenderSidebar();
</script>

