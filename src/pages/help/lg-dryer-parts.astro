---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="LG Dryer Parts Diagram | Click Any Part for Costs & Symptoms"
  description="Interactive LG dryer parts diagram — click any of the 9 major components to see what it does, how it fails, and what the fix actually costs. Built by LA's LG dryer techs."
>

<section class="page-hero">
  <div class="container">
    <h1>LG Dryer Parts — Interactive Diagram</h1>
    <p>Click any numbered part to see what it does, what breaks, and what it costs to fix.
    Same Day service across LA, Orange County and Ventura County —
    <a href="tel:3239907550">(323) 990-7550</a></p>
  </div>
</section>

<section class="parts-section">
  <div class="container">

<style is:inline>
.parts-section { padding: 2rem 0 3rem; }
.parts-section .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
.parts-controls { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.parts-btn { padding: 7px 16px; font-size: 14px; border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; cursor: pointer; background: transparent; color: rgba(255,255,255,0.6); transition: all 0.15s; }
.parts-btn.on { background: #1a6cf6; color: #fff; border-color: #1a6cf6; }
.parts-outer { display: grid; grid-template-columns: 1fr 260px; gap: 20px; align-items: start; }
@media (max-width: 768px) { .parts-outer { grid-template-columns: 1fr; } }
.parts-svg-wrap { background: #111; border: 1px solid #1e2a3a; border-radius: 12px; padding: 10px; overflow: hidden; }
.parts-svg-wrap svg { width: 100%; height: auto; display: block; }
.parts-sidebar { display: flex; flex-direction: column; gap: 6px; }
.part-card { background: #111; border: 1px solid #1e2a3a; border-radius: 9px; padding: 10px 13px; cursor: pointer; transition: border-color 0.12s, background 0.12s; }
.part-card:hover { border-color: #1a6cf6; background: #0d1a2e; }
.part-card.on { border-color: #1a6cf6; background: #0d1a2e; }
.part-card.dim { opacity: 0.25; }
.pc-top { display: flex; align-items: center; gap: 7px; }
.pc-num { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; color: #fff; flex-shrink: 0; }
.pc-nm { font-size: 14px; font-weight: 600; color: #fff; }
.pc-pr { font-size: 13px; font-weight: 600; margin-top: 3px; margin-left: 27px; }
.pc-sym { font-size: 11px; color: #8a9ab0; margin-top: 2px; margin-left: 27px; line-height: 1.35; }
.parts-info-bar { margin-top: 10px; background: #111; border: 1px solid #1e2a3a; border-radius: 10px; padding: 12px 16px; display: none; align-items: center; gap: 14px; flex-wrap: wrap; }
.parts-info-bar.on { display: flex; }
.pib-nm { font-size: 15px; font-weight: 600; color: #fff; }
.pib-pr { font-size: 14px; font-weight: 600; margin-top: 2px; }
.pib-sym { font-size: 12px; color: #8a9ab0; margin-top: 2px; }
.pib-link { margin-left: auto; padding: 8px 16px; background: #1a6cf6; color: #fff; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; white-space: nowrap; }
.pib-link:hover { background: #1558d0; }
.parts-cta { background: #111; border-top: 1px solid #1e2a3a; padding: 3rem 0; text-align: center; }
.parts-cta .container { max-width: 600px; margin: 0 auto; padding: 0 24px; }
.parts-cta h2 { font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.75rem; }
.parts-cta p { color: #8a9ab0; margin-bottom: 1.5rem; }
.cta-buttons { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.button-primary { background: #1a6cf6; color: #fff; padding: 12px 28px; border-radius: 6px; font-size: 1rem; font-weight: 600; text-decoration: none; }
.button-secondary { border: 1px solid rgba(255,255,255,0.2); color: #fff; padding: 12px 28px; border-radius: 6px; font-size: 1rem; font-weight: 600; text-decoration: none; }
.hs { cursor: pointer; }
.hs .pip { transition: transform 0.15s; transform-origin: 50% 50%; }
.hs:hover .pip, .hs.on .pip { transform: scale(1.25); }
.part-detail, .callout-line { transition: opacity 0.2s; }
.page-hero { background: #0d1117; border-bottom: 1px solid #1e2a3a; padding: 2.5rem 0 2rem; }
.page-hero .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
.page-hero h1 { font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 0.75rem; }
.page-hero p { color: #8a9ab0; font-size: 1.05rem; }
.page-hero a { color: #1a6cf6; text-decoration: none; }
</style>

<div class="parts-controls">
  <button class="parts-btn on" onclick="partsFilter('all',this)">All parts</button>
  <button class="parts-btn" onclick="partsFilter('mechanical',this)">Mechanical</button>
  <button class="parts-btn" onclick="partsFilter('heating',this)">Heating</button>
  <button class="parts-btn" onclick="partsFilter('drive',this)">Drive</button>
  <button class="parts-btn" onclick="partsFilter('housing',this)">Housing</button>
</div>

