<style>
  /* Hero */
  .hiw-hero { max-width: 720px; margin: 60px auto 80px; text-align: center; padding: 0 24px; }
  .hiw-label { font-size: 0.75rem; color: #1a6cf6; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px; }
  .hiw-hero h1 { font-size: 2.2rem; font-weight: 700; color: #ffffff; margin-bottom: 20px; line-height: 1.2; }
  .hiw-hero p { font-size: 1.05rem; color: #c8d0dc; line-height: 1.8; margin-bottom: 32px; }
  .hiw-cta-row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hiw-btn-primary { background: #1a6cf6; color: #ffffff; padding: 14px 32px; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 1rem; }
  .hiw-btn-secondary { background: transparent; color: #1a6cf6; padding: 14px 32px; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 1rem; border: 1px solid #1a6cf6; }

  /* Steps */
  .hiw-steps { max-width: 960px; margin: 0 auto; padding: 0 24px 80px; }
  .hiw-step { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; margin-bottom: 80px; position: relative; }
  .hiw-step:nth-child(even) .hiw-step-icon { order: 2; }
  .hiw-step:nth-child(even) .hiw-step-text { order: 1; }
  .hiw-step-number-bg { position: absolute; font-size: 9rem; font-weight: 700; color: rgba(26,108,246,0.05); top: -30px; left: -20px; line-height: 1; pointer-events: none; user-select: none; }
  .hiw-step-icon { display: flex; align-items: center; justify-content: center; }
  .hiw-step-icon-circle { width: 140px; height: 140px; background: rgba(26,108,246,0.08); border-radius: 50%; border: 1px solid rgba(26,108,246,0.2); display: flex; align-items: center; justify-content: center; }
  .hiw-step-icon-circle svg { width: 52px; height: 52px; stroke: #1a6cf6; fill: none; stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round; }
  .hiw-step-label { font-size: 0.75rem; color: #1a6cf6; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px; }
  .hiw-step-text h2 { font-size: 1.4rem; font-weight: 700; color: #ffffff; margin-bottom: 16px; }
  .hiw-step-text p { font-size: 0.95rem; color: #c8d0dc; line-height: 1.8; margin-bottom: 12px; }
  .hiw-step-text ul { padding-left: 20px; margin-bottom: 12px; }
  .hiw-step-text ul li { font-size: 0.95rem; color: #c8d0dc; line-height: 1.8; margin-bottom: 6px; }
