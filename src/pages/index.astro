---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/images/lg-dryer-hero.webp')"></div>
    <div class="hero-content glass">
      <span class="badge badge-blue">Same-day service available</span>
      <h1>LG Dryer Repair in Los Angeles</h1>
      <p class="subtitle">Certified technicians for all LG dryer models. Fast diagnostics, genuine parts, guaranteed results.</p>
      <div class="hero-buttons">
        <a href="tel:3239907550" class="btn btn-primary btn-lg">Call (323) 990-7550</a>
        <a href="/book" class="btn btn-secondary btn-lg">Book a Visit</a>
      </div>
      <div class="trust-bar">
        <span>&#10003; CSLB Licensed</span>
        <span>&#10003; BBB Accredited</span>
        <span>&#10003; Same-Day Service</span>
        <span>&#10003; All LG Models</span>
      </div>
    </div>
  </section>

  <!-- Two-column: AI Diagnostics + Contact Form -->
  <section class="section">
    <div class="container">
      <div class="two-col" style="position:relative;z-index:10;">

        <!-- AI Diagnostics -->
        <div class="glass">
          <h2 style="font-size:1.35rem;margin-bottom:.35rem">AI Diagnostics</h2>
          <p class="text-secondary" style="font-size:.9rem;margin-bottom:1rem">Describe your dryer issue or select symptoms below</p>

          <div class="symptom-chips" id="symptomChips">
            <button class="symptom-chip" data-symptom="Not heating">Not heating</button>
            <button class="symptom-chip" data-symptom="Not spinning">Not spinning</button>
            <button class="symptom-chip" data-symptom="Making noise">Making noise</button>
            <button class="symptom-chip" data-symptom="Not starting">Not starting</button>
            <button class="symptom-chip" data-symptom="Not drying">Not drying</button>
            <button class="symptom-chip" data-symptom="Overheating">Overheating</button>
            <button class="symptom-chip" data-symptom="Error code">Error code</button>
            <button class="symptom-chip" data-symptom="Door issue">Door issue</button>
          </div>

          <textarea class="diagnose-textarea" id="diagnoseInput" placeholder="e.g. My LG dryer runs but clothes are still damp after a full cycle..." rows="4"></textarea>

          <button class="btn btn-primary" id="diagnoseBtn" style="width:100%">Diagnose</button>

          <div class="diagnose-result" id="diagnoseResult">
            <p id="diagnoseText"></p>
          </div>
        </div>

        <!-- Contact Form with two modes -->
        <div class="glass" id="contactPanel">

          <!-- Mode Switcher -->
          <div class="mode-switcher">
            <button class="mode-btn active" id="modeCallback" data-mode="callback">
              📞 Call Me Back
            </button>
            <button class="mode-btn" id="modeBooking" data-mode="booking">
              📅 Book a Visit
            </button>
          </div>

          <!-- CALLBACK MODE -->
          <div id="formCallback">
            <p class="form-mode-desc">I have questions or want to schedule by phone</p>
            <div class="form-group">
              <label for="cbPhone">Your Phone Number <span class="required">*</span></label>
              <input type="tel" id="cbPhone" class="form-input" placeholder="(323) ___-____" />
            </div>
            <button class="btn btn-primary" style="width:100%;margin-top:.5rem" id="cbSubmit">
              Call Me Back
            </button>
            <p class="form-note">We'll call you back within 15 minutes during business hours</p>
          </div>

          <!-- BOOKING MODE -->
          <div id="formBooking" style="display:none">
            <p class="form-mode-desc">Schedule your LG dryer repair appointment</p>
            <div class="form-group">
              <label for="bkPhone">Phone Number <span class="required">*</span></label>
              <input type="tel" id="bkPhone" class="form-input" placeholder="(323) ___-____" />
            </div>
            <div class="form-group">
              <label for="bkName">Full Name</label>
              <input type="text" id="bkName" class="form-input" placeholder="John Smith" />
            </div>
            <div class="form-group">
              <label for="bkAddress">Address</label>
              <input type="text" id="bkAddress" class="form-input" placeholder="123 Main St, Los Angeles, CA" />
            </div>
            <div class="form-group">
              <label for="bkTime">Preferred Time</label>
              <select id="bkTime" class="form-input">
                <option value="">Select a time...</option>
                <option>8:00 AM – 10:00 AM</option>
                <option>10:00 AM – 12:00 PM</option>
                <option>12:00 PM – 2:00 PM</option>
                <option>2:00 PM – 4:00 PM</option>
                <option>4:00 PM – 6:00 PM</option>
              </select>
            </div>
            <div class="form-group">
              <label for="bkComments">Comments</label>
              <textarea id="bkComments" class="form-input" rows="2" placeholder="Describe the issue, model number, etc."></textarea>
            </div>
            <button class="btn btn-primary" style="width:100%;margin-top:.25rem" id="bkSubmit">
              Confirm Booking
            </button>
          </div>

          <!-- Success message (hidden) -->
          <div id="formSuccess" style="display:none;text-align:center;padding:1.5rem 0">
            <div style="font-size:2.5rem;margin-bottom:.75rem">✅</div>
            <h3 style="margin:0 0 .5rem;color:var(--accent)">Got it!</h3>
            <p class="text-secondary" style="font-size:.9rem" id="successMsg">We'll be in touch shortly.</p>
            <a href="tel:3239907550" class="btn btn-primary" style="margin-top:1rem;display:inline-flex">
              Or call now: (323) 990-7550
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .mode-switcher {
    display: flex;
    gap: .5rem;
    margin-bottom: 1.25rem;
    background: rgba(255,255,255,.05);
    border-radius: 10px;
    padding: 4px;
  }
  .mode-btn {
    flex: 1;
    padding: .6rem .75rem;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary, #888);
    font-size: .875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }
  .mode-btn.active {
    background: var(--accent, #1a6cf6);
    color: #fff;
  }
  .form-mode-desc {
    font-size: .875rem;
    color: var(--text-secondary, #888);
    margin: 0 0 1rem;
  }
  .form-note {
    font-size: .78rem;
    color: var(--text-secondary, #888);
    text-align: center;
    margin: .6rem 0 0;
  }
  .required {
    color: var(--accent, #1a6cf6);
  }
  textarea.form-input {
    resize: vertical;
    min-height: 64px;
  }
</style>

<script>
  // ── Symptom chips ──────────────────────────────────────────
  document.querySelectorAll('.symptom-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('active');
      const textarea = document.getElementById('diagnoseInput') as HTMLTextAreaElement;
      const active = document.querySelectorAll('.symptom-chip.active');
      const symptoms = Array.from(active).map(c => (c as HTMLElement).dataset.symptom);
      if (symptoms.length > 0) {
        const current = textarea.value.replace(/^Selected symptoms:.*\n?/, '');
        textarea.value = `Selected symptoms: ${symptoms.join(', ')}\n${current}`.trim();
      }
    });
  });

  // ── AI Diagnose ────────────────────────────────────────────
  document.getElementById('diagnoseBtn')?.addEventListener('click', async () => {
    const input = (document.getElementById('diagnoseInput') as HTMLTextAreaElement)?.value;
    if (!input.trim()) return;

    const resultDiv = document.getElementById('diagnoseResult')!;
    const resultText = document.getElementById('diagnoseText')!;
    const btn = document.getElementById('diagnoseBtn') as HTMLButtonElement;

    btn.textContent = 'Analyzing...';
    btn.disabled = true;
    resultDiv.classList.add('visible');
    resultText.textContent = 'Running diagnostics...';

    try {
      const res = await fetch('/api/diagnose', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userInput: input })
      });
      const data = await res.json();
      resultText.textContent = data.result;

      // Send AI diagnostic conversation to Telegram for analysis
      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        const aiResponse = resultText.textContent || (document.getElementById('diagnoseText') as HTMLElement).textContent || '';
        const pageUrl = window.location.href;

        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: '—',
            message: `📍 Page: ${pageUrl}\n\n👤 User: ${userInput}\n\n🔧 AI Response: ${aiResponse.substring(0, 800)}`
          })
        });
      } catch (e) {
        // Silent fail — don't interrupt user experience
      }
    } catch (err: any) {
      resultText.textContent = `Could not connect to AI service. Please call (323) 990-7550 for a free phone diagnosis.`;

      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics — ERROR',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: '—',
            message: `📍 Page: ${window.location.href}\n\n👤 User tried: ${userInput}\n\n❌ AI widget failed to connect`
          })
        });
      } catch (e) {}
    }

    btn.textContent = 'Diagnose';
    btn.disabled = false;
  });

  // ── Mode switcher ──────────────────────────────────────────
  const modeCallback = document.getElementById('modeCallback')!;
  const modeBooking  = document.getElementById('modeBooking')!;
  const formCallback = document.getElementById('formCallback')!;
  const formBooking  = document.getElementById('formBooking')!;

  modeCallback.addEventListener('click', () => {
    modeCallback.classList.add('active');
    modeBooking.classList.remove('active');
    formCallback.style.display = 'block';
    formBooking.style.display  = 'none';
  });

  modeBooking.addEventListener('click', () => {
    modeBooking.classList.add('active');
    modeCallback.classList.remove('active');
    formBooking.style.display  = 'block';
    formCallback.style.display = 'none';
  });

  // ── Generic submit helper ──────────────────────────────────
  async function submitForm(payload: any, btn: HTMLButtonElement, successMsg: string) {
    btn.disabled = true;
    const origText = btn.textContent;
    btn.textContent = 'Sending...';

    try {
      // Send via server-side proxy (handles both Resend email and Telegram)
      try {
        const resendRes = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const resendData = await resendRes.json();
        console.log('Resend response:', resendData);
      } catch (resendErr) {
        console.error('Resend error:', resendErr);
      }

      // Show success (Telegram is the primary channel, Resend may fail from browser)
      formCallback.style.display = 'none';
      formBooking.style.display = 'none';
      document.querySelector('.mode-switcher')!.setAttribute('style', 'display:none');
      document.getElementById('successMsg')!.textContent = successMsg;
      document.getElementById('formSuccess')!.style.display = 'block';
    } catch (err) {
      console.error('Submit error:', err);
      alert('Network error. Please call (323) 990-7550 directly.');
      btn.disabled = false;
      btn.textContent = origText;
    }
  }

  // ── Callback submit ────────────────────────────────────────
  document.getElementById('cbSubmit')?.addEventListener('click', async () => {
    const phone = (document.getElementById('cbPhone') as HTMLInputElement).value.trim();
    if (!phone) {
      alert('Please enter your phone number.');
      return;
    }
    await submitForm(
        { type: 'callback', phone },
        document.getElementById('cbSubmit') as HTMLButtonElement,
        "We'll call you back within 15 minutes during business hours (Mon–Sat 8am–7pm)."
    );
  });

  // ── Booking submit ─────────────────────────────────────────
  document.getElementById('bkSubmit')?.addEventListener('click', async () => {
    const phone    = (document.getElementById('bkPhone')    as HTMLInputElement).value.trim();
    const name     = (document.getElementById('bkName')     as HTMLInputElement).value.trim();
    const address  = (document.getElementById('bkAddress')  as HTMLInputElement).value.trim();
    const time     = (document.getElementById('bkTime')     as HTMLSelectElement).value;
    const comments = (document.getElementById('bkComments') as HTMLTextAreaElement).value.trim();

    if (!phone) {
      alert('Please enter your phone number.');
      return;
    }

    await submitForm(
        { type: 'booking', phone, name, address, time, comments },
        document.getElementById('bkSubmit') as HTMLButtonElement,
        "Your booking request is received! We'll confirm your appointment shortly."
    );
  });
</script>

<script src="/scripts/dryer-idle-animation-v2.js" defer></script>