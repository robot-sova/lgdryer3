---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="LG Dryer Repair Near You — LA, Orange County & Ventura | Same Day"
  description="Need LG dryer repair near you? Same-day visits across LA, Orange County and Ventura County. Certified techs, OEM parts, $65 diagnostic waived with the repair. Call (323) 990-7550 — we can usually come today."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/images/lg-dryer-hero.webp')"></div>
    <div class="hero-content glass">
      <span class="badge badge-blue">Same-day service available</span>
      <h1>LG Dryer Repair in Los Angeles</h1>
      <p class="subtitle">LG Dryer Repair is a team of certified technicians specializing in LG appliance repair, maintenance, and installation. We serve Los Angeles County, Orange County, and Ventura County — same-day service, OEM parts, and guaranteed results.</p>
      <div class="hero-buttons">
        <a href="tel:3239907550" class="btn btn-primary btn-lg">Call (323) 990-7550</a>
      </div>
      <div class="trust-bar">
        <span>&#10003; Bureau of Household Goods and Services #49573</span>
        <span>&#10003; BBB Accredited</span>
        <span>&#10003; Same-Day Service</span>
        <span>&#10003; All LG Models</span>
      </div>

      <div class="hero-form">
        <div class="hero-form-tabs">
          <button class="hero-tab active" id="htCallback">
            📞 Call me back in 15 min
          </button>
          <button class="hero-tab" id="htBooking">
            📅 Schedule a visit
          </button>
        </div>

        <!-- Callback -->
        <div class="hero-form-body" id="hfCallback">
          <p class="hero-form-hint">Leave your number — we call back within 15 minutes during business hours (Mon–Sat 8AM–8PM)</p>
          <div class="hero-form-row">
            <input type="tel" id="hfPhone" class="hero-input" placeholder="(323) ___-____" />
            <button class="btn btn-primary" id="hfSubmitCallback">Call Me Back</button>
          </div>
        </div>

        <!-- Booking -->
        <div class="hero-form-body" id="hfBooking" style="display:none">
          <p class="hero-form-hint">Fill in your details — we confirm the appointment by phone same day</p>
          <div class="hero-form-grid">
            <input type="tel" id="hfBkPhone" class="hero-input" placeholder="Phone *" />
            <input type="text" id="hfBkName" class="hero-input" placeholder="Your name" />
            <input type="text" id="hfBkAddress" class="hero-input" placeholder="Address" />
            <select id="hfBkTime" class="hero-input">
              <option value="">Preferred time...</option>
              <option>8:00 AM – 10:00 AM</option>
              <option>10:00 AM – 12:00 PM</option>
              <option>12:00 PM – 2:00 PM</option>
              <option>2:00 PM – 4:00 PM</option>
              <option>4:00 PM – 6:00 PM</option>
            </select>
          </div>
          <button class="btn btn-primary" style="width:100%;margin-top:12px" id="hfSubmitBooking">Confirm Booking</button>
        </div>

        <!-- Success -->
        <div class="hero-form-body" id="hfSuccess" style="display:none;text-align:center;padding:20px 0">
          <div style="font-size:2rem;margin-bottom:8px">✅</div>
          <p id="hfSuccessMsg" style="color:#fff;font-size:1rem;margin:0"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Internal links -->
  <section class="home-links">
    <div class="home-links-inner">
      <div class="home-links-col">
        <h2>Popular Repairs</h2>
        <ul>
          <li><a href="/repairs/lg-dryer-heating-element-replacement/">Heating Element Replacement</a></li>
          <li><a href="/repairs/lg-dryer-thermal-fuse-replacement/">Thermal Fuse Replacement</a></li>
          <li><a href="/repairs/lg-dryer-drum-roller-replacement/">Drum Roller Replacement</a></li>
          <li><a href="/repairs/lg-dryer-belt-replacement/">Belt Replacement</a></li>
          <li><a href="/repairs/lg-dryer-igniter-replacement/">Igniter Replacement</a></li>
          <li><a href="/repairs/lg-dryer-motor-replacement/">Motor Replacement</a></li>
        </ul>
        <a href="/repairs/" class="home-links-more">All repairs →</a>
      </div>
      <div class="home-links-col">
        <h2>Browse by Symptom</h2>
        <ul>
          <li><a href="/symptoms/lg-dryer-not-heating/">Not Heating</a></li>
          <li><a href="/symptoms/lg-dryer-not-spinning/">Not Spinning</a></li>
          <li><a href="/symptoms/lg-dryer-not-starting/">Not Starting</a></li>
          <li><a href="/symptoms/lg-dryer-making-noise/">Making Noise</a></li>
          <li><a href="/symptoms/lg-dryer-not-drying/">Not Drying</a></li>
          <li><a href="/symptoms/lg-dryer-overheating/">Overheating</a></li>
        </ul>
        <a href="/symptoms/" class="home-links-more">All symptoms →</a>
      </div>
      <div class="home-links-col">
        <h2>Transparent Pricing</h2>
        <ul>
          <li><a href="/price-list/lg-dryer-repair-cost/">LG Dryer Repair Cost</a></li>
          <li><a href="/price-list/lg-dryer-heating-element-replacement-cost/">Heating Element Cost</a></li>
          <li><a href="/price-list/lg-dryer-thermal-fuse-replacement-cost/">Thermal Fuse Cost</a></li>
          <li><a href="/price-list/lg-dryer-drum-roller-replacement-cost/">Drum Roller Cost</a></li>
          <li><a href="/price-list/lg-dryer-belt-replacement-cost/">Belt Replacement Cost</a></li>
          <li><a href="/price-list/lg-dryer-motor-replacement-cost/">Motor Replacement Cost</a></li>
        </ul>
        <a href="/price-list/" class="home-links-more">Full price list →</a>
      </div>
      <div class="home-links-col">
        <h2>Service Areas</h2>
        <ul>
          <li><a href="/areas/lg-dryer-repair-los-angeles/">Los Angeles</a></li>
          <li><a href="/areas/lg-dryer-repair-beverly-hills/">Beverly Hills</a></li>
          <li><a href="/areas/lg-dryer-repair-santa-monica/">Santa Monica</a></li>
          <li><a href="/areas/lg-dryer-repair-irvine/">Irvine</a></li>
          <li><a href="/areas/lg-dryer-repair-laguna-niguel/">Laguna Niguel</a></li>
          <li><a href="/areas/lg-dryer-repair-mission-viejo/">Mission Viejo</a></li>
          <li><a href="/areas/lg-dryer-repair-woodland-hills/">Woodland Hills</a></li>
          <li><a href="/areas/lg-dryer-repair-thousand-oaks/">Thousand Oaks</a></li>
          <li><a href="/areas/lg-dryer-repair-pasadena/">Pasadena</a></li>
        </ul>
        <a href="/areas/" class="home-links-more">All 45+ cities →</a>
      </div>
    </div>
  </section>

  <!-- Two-column: AI Diagnostics + Contact Form -->
  <section class="section">
    <div class="container">
      <div class="two-col" style="position:relative;z-index:10;">

        <!-- AI Diagnostics -->
        <div class="glass">
          <h2 style="font-size:1.35rem;margin-bottom:.35rem">AI Diagnostics</h2>

          <div class="appliance-toggle">
            <button class="appliance-tab active" id="applianceDryer" type="button">Dryer</button>
            <button class="appliance-tab" id="applianceWasher" type="button">Washer</button>
          </div>

          <p class="text-secondary" id="diagnoseSubtitle" style="font-size:.9rem;margin-bottom:1rem">Describe your dryer issue or select symptoms below</p>

          <div class="symptom-chips" id="symptomChips"></div>

          <textarea class="diagnose-textarea" id="diagnoseInput" placeholder="e.g. My LG dryer runs but clothes are still damp after a full cycle..." rows="4"></textarea>

          <p class="diagnose-phone-hint">Enter your phone — our tech will follow up with an exact quote.</p>
          <input type="tel" id="diagnosePhone" class="diagnose-phone" placeholder="(323) 555-0123" autocomplete="tel" />
          <p class="diagnose-phone-error" id="diagnosePhoneError">Please enter a valid 10-digit phone number</p>

          <button class="btn btn-primary" id="diagnoseBtn" style="width:100%">Diagnose</button>

          <div class="diagnose-result" id="diagnoseResult">
            <p id="diagnoseText"></p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .home-links {
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 24px 0;
  }
  .home-links-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .home-links-col h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 14px;
  }
  .home-links-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .home-links-col li {
    margin-bottom: 8px;
  }
  .home-links-col a {
    color: #c8d0dc;
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s;
  }
  .home-links-col a:hover {
    color: #1a6cf6;
  }
  .home-links-more {
    display: inline-block;
    margin-top: 8px;
    font-size: 0.85rem;
    color: #1a6cf6 !important;
  }
  @media (max-width: 768px) {
    .home-links-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
  @media (max-width: 480px) {
    .home-links-inner {
      grid-template-columns: 1fr;
    }
  }

  .mode-switcher {
    display: flex;
    gap: .5rem;
    margin-bottom: 1.25rem;
    background: rgba(255,255,255,.05);
    border-radius: 10px;
    padding: 4px;
  }
  .mode-btn {
    flex: 1;
    padding: .6rem .75rem;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary, #888);
    font-size: .875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }
  .mode-btn.active {
    background: var(--accent, #1a6cf6);
    color: #fff;
  }
  .form-mode-desc {
    font-size: .875rem;
    color: var(--text-secondary, #888);
    margin: 0 0 1rem;
  }
  .form-note {
    font-size: .85rem;
    color: var(--text-secondary, #888);
    text-align: center;
    margin: .6rem 0 0;
  }
  .required {
    color: var(--accent, #1a6cf6);
  }
  textarea.form-input {
    resize: vertical;
    min-height: 64px;
  }
  .two-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
  }
  .container {
    max-width: 860px;
    margin: 0 auto;
  }
  .hero-content {
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
  }
  .hero h1 { font-size: clamp(2rem, 4vw, 2.8rem); }
  .hero .subtitle { font-size: 1.1rem; line-height: 1.7; }
  .trust-bar { font-size: 1rem; }
  .glass h2 { font-size: 1.4rem; }
  .glass p { font-size: 1rem; }
  .symptom-chip { font-size: 0.95rem; }
  .diagnose-textarea { font-size: 1rem; }
  .btn { font-size: 1rem; }
  .form-mode-desc { font-size: 1rem; }
  label { font-size: 1rem; }
  .form-input { font-size: 1rem; }
  .form-note { font-size: 0.9rem; }
  .hero-buttons {
    display: flex;
    justify-content: center;
  }
  .section {
    padding-top: 0;
    margin-top: 24px;
  }

  @media (min-width: 769px) {
    .section {
      margin-top: -360px;
    }
  }
  .diagnose-textarea {
    min-height: 160px;
  }
  .glass {
    padding: 28px;
  }

  .hero-form {
    margin-top: 28px;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 20px 24px;
    max-width: 860px;
    width: 100%;
  }
  .hero-form-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }
  .hero-tab {
    flex: 1;
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: rgba(255,255,255,0.6);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .hero-tab.active {
    background: #1a6cf6;
    border-color: #1a6cf6;
    color: #fff;
  }
  .hero-tab:hover:not(.active) {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  /* Washer/Dryer toggle for AI diagnostics */
  .appliance-toggle {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
  }
  .appliance-tab {
    flex: 1;
    padding: 9px 16px;
    border-radius: 100px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }
  .appliance-tab.active {
    background: #1a6cf6;
    border-color: #1a6cf6;
    color: #fff;
  }
  .appliance-tab:hover:not(.active) {
    background: rgba(26,108,246,0.15);
    border-color: rgba(26,108,246,0.3);
    color: #1a6cf6;
  }

  /* Required phone field for AI diagnostics */
  .diagnose-phone-hint {
    font-size: 0.9rem;
    color: #8a9ab0;
    margin: 0 0 8px 0;
  }
  .diagnose-phone {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid #1e2a3a;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    color: #fff;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    transition: border-color 0.15s;
  }
  .diagnose-phone::placeholder { color: rgba(255,255,255,0.3); }
  .diagnose-phone:focus { outline: none; border-color: rgba(26,108,246,0.5); }
  .diagnose-phone.error { border-color: #e5484d; }
  .diagnose-phone-error {
    display: none;
    font-size: 0.9rem;
    color: #e5484d;
    margin: 0 0 0.75rem 0;
  }
  .diagnose-phone-error.visible { display: block; }
  .hero-form-hint {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    margin: 0 0 14px;
    line-height: 1.5;
  }
  .hero-form-row {
    display: flex;
    gap: 10px;
  }
  .hero-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .hero-input {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 11px 14px;
    color: #fff;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .hero-input::placeholder { color: rgba(255,255,255,0.4); }
  .hero-input:focus { border-color: #1a6cf6; }
  .hero-input option { background: #111; color: #fff; }

  @media (max-width: 600px) {
    .hero-form-row { flex-direction: column; }
    .hero-form-grid { grid-template-columns: 1fr; }
    .hero-tab { font-size: 0.82rem; padding: 9px 10px; }
  }
</style>

<script>
  // ── Appliance mode (washer/dryer) ──────────────────────────
  const APPLIANCE_CHIPS: Record<string, string[]> = {
    dryer: ['Not heating', 'Not spinning', 'Making noise', 'Not starting', 'Not drying', 'Overheating', 'Error code', 'Door issue'],
    washer: ['Not draining', 'Not spinning', 'Leaking', 'Not filling', "Won't start", 'Shaking & loud', 'Error code', "Door won't open"]
  };
  const APPLIANCE_TEXT: Record<string, { subtitle: string; placeholder: string }> = {
    dryer: {
      subtitle: 'Describe your dryer issue or select symptoms below',
      placeholder: 'e.g. My LG dryer runs but clothes are still damp after a full cycle...'
    },
    washer: {
      subtitle: 'Describe your washer issue or select symptoms below',
      placeholder: "e.g. My LG washer won't drain and the door is locked..."
    }
  };

  let currentAppliance = 'dryer';

  function syncTextareaSymptoms() {
    const textarea = document.getElementById('diagnoseInput') as HTMLTextAreaElement;
    if (!textarea) return;
    const active = document.querySelectorAll('.symptom-chip.active');
    const symptoms = Array.from(active).map(c => (c as HTMLElement).dataset.symptom);
    const current = textarea.value.replace(/^Selected symptoms:.*\n?/, '');
    textarea.value = symptoms.length > 0
      ? `Selected symptoms: ${symptoms.join(', ')}\n${current}`.trim()
      : current.trim();
  }

  function renderChips() {
    const container = document.getElementById('symptomChips');
    if (!container) return;
    container.innerHTML = '';
    APPLIANCE_CHIPS[currentAppliance].forEach(sym => {
      const btn = document.createElement('button');
      btn.className = 'symptom-chip';
      btn.dataset.symptom = sym;
      btn.textContent = sym;
      btn.addEventListener('click', () => {
        btn.classList.toggle('active');
        syncTextareaSymptoms();
      });
      container.appendChild(btn);
    });
  }

  function setAppliance(appliance: string) {
    currentAppliance = (appliance === 'washer') ? 'washer' : 'dryer';

    document.getElementById('applianceDryer')?.classList.toggle('active', currentAppliance === 'dryer');
    document.getElementById('applianceWasher')?.classList.toggle('active', currentAppliance === 'washer');

    const subtitle = document.getElementById('diagnoseSubtitle');
    if (subtitle) subtitle.textContent = APPLIANCE_TEXT[currentAppliance].subtitle;

    const textarea = document.getElementById('diagnoseInput') as HTMLTextAreaElement;
    if (textarea) {
      textarea.setAttribute('placeholder', APPLIANCE_TEXT[currentAppliance].placeholder);
      // clear any stale "Selected symptoms:" line when switching modes
      textarea.value = textarea.value.replace(/^Selected symptoms:.*\n?/, '').trim();
    }

    renderChips();
  }

  document.getElementById('applianceDryer')?.addEventListener('click', () => setAppliance('dryer'));
  document.getElementById('applianceWasher')?.addEventListener('click', () => setAppliance('washer'));

  // Read ?appliance=washer from URL (whitelist; anything else → dryer)
  const initialAppliance = new URLSearchParams(window.location.search).get('appliance') === 'washer' ? 'washer' : 'dryer';
  setAppliance(initialAppliance);

  // ── AI Diagnose ────────────────────────────────────────────
  document.getElementById('diagnoseBtn')?.addEventListener('click', async () => {
    const input = (document.getElementById('diagnoseInput') as HTMLTextAreaElement)?.value;
    if (!input.trim()) return;

    // ── Required phone (both modes): normalize + validate before sending ──
    const phoneField = document.getElementById('diagnosePhone') as HTMLInputElement;
    const phoneError = document.getElementById('diagnosePhoneError')!;
    const phoneDigits = (phoneField?.value || '').replace(/\D/g, '');
    const phoneValid = phoneDigits.length === 10 || (phoneDigits.length === 11 && phoneDigits.startsWith('1'));
    if (!phoneValid) {
      phoneField?.classList.add('error');
      phoneError.classList.add('visible');
      phoneField?.focus();
      return; // no valid phone → no diagnosis request
    }
    phoneField?.classList.remove('error');
    phoneError.classList.remove('visible');

    const resultDiv = document.getElementById('diagnoseResult')!;
    const resultText = document.getElementById('diagnoseText')!;
    const btn = document.getElementById('diagnoseBtn') as HTMLButtonElement;

    btn.textContent = 'Analyzing...';
    btn.disabled = true;
    resultDiv.classList.add('visible');
    resultText.textContent = 'Running diagnostics...';

    try {
      const res = await fetch('/api/diagnose', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userInput: input, appliance: currentAppliance })
      });
      const data = await res.json();
      resultText.textContent = data.result;

      // Send AI diagnostic conversation to Telegram for analysis
      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        const aiResponse = resultText.textContent || (document.getElementById('diagnoseText') as HTMLElement).textContent || '';
        const pageUrl = window.location.href;

        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: phoneDigits,
            appliance: currentAppliance,
            source: 'AI Diagnosis',
            message: `📍 Page: ${pageUrl}\n\n👤 User: ${userInput}\n\n🔧 AI Response: ${aiResponse.substring(0, 800)}`
          })
        });
      } catch (e) {
        // Silent fail — don't interrupt user experience
      }
    } catch (err: any) {
      resultText.textContent = `Could not connect to AI service. Please call (323) 990-7550 for a free phone diagnosis.`;

      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics — ERROR',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: phoneDigits,
            appliance: currentAppliance,
            source: 'AI Diagnosis',
            message: `📍 Page: ${window.location.href}\n\n👤 User tried: ${userInput}\n\n❌ AI widget failed to connect`
          })
        });
      } catch (e) {}
    }

    btn.textContent = 'Diagnose';
    btn.disabled = false;
  });

  // ── Hero form tabs ─────────────────────────────────────────
  document.getElementById('htCallback')?.addEventListener('click', () => {
    document.getElementById('htCallback')!.classList.add('active');
    document.getElementById('htBooking')!.classList.remove('active');
    document.getElementById('hfCallback')!.style.display = 'block';
    document.getElementById('hfBooking')!.style.display = 'none';
  });
  document.getElementById('htBooking')?.addEventListener('click', () => {
    document.getElementById('htBooking')!.classList.add('active');
    document.getElementById('htCallback')!.classList.remove('active');
    document.getElementById('hfBooking')!.style.display = 'block';
    document.getElementById('hfCallback')!.style.display = 'none';
  });

  async function heroSubmit(payload: any, successMsg: string) {
    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      document.getElementById('hfCallback')!.style.display = 'none';
      document.getElementById('hfBooking')!.style.display = 'none';
      document.querySelector('.hero-form-tabs')!.setAttribute('style','display:none');
      document.getElementById('hfSuccessMsg')!.textContent = successMsg;
      document.getElementById('hfSuccess')!.style.display = 'block';
    } catch(e) {
      alert('Network error. Please call (323) 990-7550 directly.');
    }
  }

  document.getElementById('hfSubmitCallback')?.addEventListener('click', async () => {
    const phone = (document.getElementById('hfPhone') as HTMLInputElement).value.trim();
    if (!phone) { alert('Please enter your phone number.'); return; }
    await heroSubmit({ type: 'callback', phone }, "We'll call you back within 15 minutes during business hours.");
  });

  document.getElementById('hfSubmitBooking')?.addEventListener('click', async () => {
    const phone = (document.getElementById('hfBkPhone') as HTMLInputElement).value.trim();
    if (!phone) { alert('Please enter your phone number.'); return; }
    const name = (document.getElementById('hfBkName') as HTMLInputElement).value.trim();
    const address = (document.getElementById('hfBkAddress') as HTMLInputElement).value.trim();
    const time = (document.getElementById('hfBkTime') as HTMLSelectElement).value;
    await heroSubmit({ type: 'booking', phone, name, address, time }, "Booking confirmed! We'll call to confirm your appointment shortly.");
  });
</script>

