---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/images/lg-dryer-hero.webp')"></div>
    <div class="hero-content glass">
      <span class="badge badge-blue">Same-day service available</span>
      <h1>LG Dryer Repair in Los Angeles</h1>
      <p class="subtitle">LG Dryer Repair is a team of certified technicians specializing in LG appliance repair, maintenance, and installation. We serve Los Angeles County, Orange County, and Ventura County — same-day service, OEM parts, and guaranteed results.</p>
      <div class="hero-buttons">
        <a href="tel:3239907550" class="btn btn-primary btn-lg">Call (323) 990-7550</a>
      </div>
      <div class="trust-bar">
        <span>&#10003; CSLB Licensed</span>
        <span>&#10003; BBB Accredited</span>
        <span>&#10003; Same-Day Service</span>
        <span>&#10003; All LG Models</span>
      </div>

      <div class="hero-form">
        <div class="hero-form-tabs">
          <button class="hero-tab active" id="htCallback">
            📞 Call me back in 15 min
          </button>
          <button class="hero-tab" id="htBooking">
            📅 Schedule a visit
          </button>
        </div>

        <!-- Callback -->
        <div class="hero-form-body" id="hfCallback">
          <p class="hero-form-hint">Leave your number — we call back within 15 minutes during business hours (Mon–Sat 8am–7pm)</p>
          <div class="hero-form-row">
            <input type="tel" id="hfPhone" class="hero-input" placeholder="(323) ___-____" />
            <button class="btn btn-primary" id="hfSubmitCallback">Call Me Back</button>
          </div>
        </div>

        <!-- Booking -->
        <div class="hero-form-body" id="hfBooking" style="display:none">
          <p class="hero-form-hint">Fill in your details — we confirm the appointment by phone same day</p>
          <div class="hero-form-grid">
            <input type="tel" id="hfBkPhone" class="hero-input" placeholder="Phone *" />
            <input type="text" id="hfBkName" class="hero-input" placeholder="Your name" />
            <input type="text" id="hfBkAddress" class="hero-input" placeholder="Address" />
            <select id="hfBkTime" class="hero-input">
              <option value="">Preferred time...</option>
              <option>8:00 AM – 10:00 AM</option>
              <option>10:00 AM – 12:00 PM</option>
              <option>12:00 PM – 2:00 PM</option>
              <option>2:00 PM – 4:00 PM</option>
              <option>4:00 PM – 6:00 PM</option>
            </select>
          </div>
          <button class="btn btn-primary" style="width:100%;margin-top:12px" id="hfSubmitBooking">Confirm Booking</button>
        </div>

        <!-- Success -->
        <div class="hero-form-body" id="hfSuccess" style="display:none;text-align:center;padding:20px 0">
          <div style="font-size:2rem;margin-bottom:8px">✅</div>
          <p id="hfSuccessMsg" style="color:#fff;font-size:1rem;margin:0"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Two-column: AI Diagnostics + Contact Form -->
  <section class="section">
    <div class="container">
      <div class="two-col" style="position:relative;z-index:10;">

        <!-- AI Diagnostics -->
        <div class="glass">
          <h2 style="font-size:1.35rem;margin-bottom:.35rem">AI Diagnostics</h2>
          <p class="text-secondary" style="font-size:.9rem;margin-bottom:1rem">Describe your dryer issue or select symptoms below</p>

          <div class="symptom-chips" id="symptomChips">
            <button class="symptom-chip" data-symptom="Not heating">Not heating</button>
            <button class="symptom-chip" data-symptom="Not spinning">Not spinning</button>
            <button class="symptom-chip" data-symptom="Making noise">Making noise</button>
            <button class="symptom-chip" data-symptom="Not starting">Not starting</button>
            <button class="symptom-chip" data-symptom="Not drying">Not drying</button>
            <button class="symptom-chip" data-symptom="Overheating">Overheating</button>
            <button class="symptom-chip" data-symptom="Error code">Error code</button>
            <button class="symptom-chip" data-symptom="Door issue">Door issue</button>
          </div>

          <textarea class="diagnose-textarea" id="diagnoseInput" placeholder="e.g. My LG dryer runs but clothes are still damp after a full cycle..." rows="4"></textarea>

          <button class="btn btn-primary" id="diagnoseBtn" style="width:100%">Diagnose</button>

          <div class="diagnose-result" id="diagnoseResult">
            <p id="diagnoseText"></p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .mode-switcher {
    display: flex;
    gap: .5rem;
    margin-bottom: 1.25rem;
    background: rgba(255,255,255,.05);
    border-radius: 10px;
    padding: 4px;
  }
  .mode-btn {
    flex: 1;
    padding: .6rem .75rem;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary, #888);
    font-size: .875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }
  .mode-btn.active {
    background: var(--accent, #1a6cf6);
    color: #fff;
  }
  .form-mode-desc {
    font-size: .875rem;
    color: var(--text-secondary, #888);
    margin: 0 0 1rem;
  }
  .form-note {
    font-size: .78rem;
    color: var(--text-secondary, #888);
    text-align: center;
    margin: .6rem 0 0;
  }
  .required {
    color: var(--accent, #1a6cf6);
  }
  textarea.form-input {
    resize: vertical;
    min-height: 64px;
  }
  .two-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto;
    width: 100%;
  }
  .container {
    max-width: 860px;
    margin: 0 auto;
  }
  .hero-content {
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
  }
  .hero h1 { font-size: clamp(2rem, 4vw, 2.8rem); }
  .hero .subtitle { font-size: 1.1rem; line-height: 1.7; }
  .trust-bar { font-size: 1rem; }
  .glass h2 { font-size: 1.4rem; }
  .glass p { font-size: 1rem; }
  .symptom-chip { font-size: 0.95rem; }
  .diagnose-textarea { font-size: 1rem; }
  .btn { font-size: 1rem; }
  .form-mode-desc { font-size: 1rem; }
  label { font-size: 1rem; }
  .form-input { font-size: 1rem; }
  .form-note { font-size: 0.9rem; }
  .hero-buttons {
    display: flex;
    justify-content: center;
  }
  .section {
    padding-top: 0;
    margin-top: 24px;
  }

  @media (min-width: 769px) {
    .section {
      margin-top: -360px;
    }
  }
  .diagnose-textarea {
    min-height: 160px;
  }
  .glass {
    padding: 28px;
  }

  .hero-form {
    margin-top: 28px;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 20px 24px;
    max-width: 860px;
    width: 100%;
  }
  .hero-form-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }
  .hero-tab {
    flex: 1;
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: rgba(255,255,255,0.6);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .hero-tab.active {
    background: #1a6cf6;
    border-color: #1a6cf6;
    color: #fff;
  }
  .hero-tab:hover:not(.active) {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }
  .hero-form-hint {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.55);
    margin: 0 0 14px;
    line-height: 1.5;
  }
  .hero-form-row {
    display: flex;
    gap: 10px;
  }
  .hero-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .hero-input {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 11px 14px;
    color: #fff;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .hero-input::placeholder { color: rgba(255,255,255,0.4); }
  .hero-input:focus { border-color: #1a6cf6; }
  .hero-input option { background: #111; color: #fff; }

  @media (max-width: 600px) {
    .hero-form-row { flex-direction: column; }
    .hero-form-grid { grid-template-columns: 1fr; }
    .hero-tab { font-size: 0.82rem; padding: 9px 10px; }
  }
</style>

<script>
  // ── Symptom chips ──────────────────────────────────────────
  document.querySelectorAll('.symptom-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      chip.classList.toggle('active');
      const textarea = document.getElementById('diagnoseInput') as HTMLTextAreaElement;
      const active = document.querySelectorAll('.symptom-chip.active');
      const symptoms = Array.from(active).map(c => (c as HTMLElement).dataset.symptom);
      if (symptoms.length > 0) {
        const current = textarea.value.replace(/^Selected symptoms:.*\n?/, '');
        textarea.value = `Selected symptoms: ${symptoms.join(', ')}\n${current}`.trim();
      }
    });
  });

  // ── AI Diagnose ────────────────────────────────────────────
  document.getElementById('diagnoseBtn')?.addEventListener('click', async () => {
    const input = (document.getElementById('diagnoseInput') as HTMLTextAreaElement)?.value;
    if (!input.trim()) return;

    const resultDiv = document.getElementById('diagnoseResult')!;
    const resultText = document.getElementById('diagnoseText')!;
    const btn = document.getElementById('diagnoseBtn') as HTMLButtonElement;

    btn.textContent = 'Analyzing...';
    btn.disabled = true;
    resultDiv.classList.add('visible');
    resultText.textContent = 'Running diagnostics...';

    try {
      const res = await fetch('/api/diagnose', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userInput: input })
      });
      const data = await res.json();
      resultText.textContent = data.result;

      // Send AI diagnostic conversation to Telegram for analysis
      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        const aiResponse = resultText.textContent || (document.getElementById('diagnoseText') as HTMLElement).textContent || '';
        const pageUrl = window.location.href;

        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: '—',
            message: `📍 Page: ${pageUrl}\n\n👤 User: ${userInput}\n\n🔧 AI Response: ${aiResponse.substring(0, 800)}`
          })
        });
      } catch (e) {
        // Silent fail — don't interrupt user experience
      }
    } catch (err: any) {
      resultText.textContent = `Could not connect to AI service. Please call (323) 990-7550 for a free phone diagnosis.`;

      try {
        const userInput = (document.getElementById('diagnoseInput') as HTMLTextAreaElement).value;
        await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: '🤖 AI Diagnostics — ERROR',
            email: 'ai-diagnostics@lgdryer.repair',
            phone: '—',
            message: `📍 Page: ${window.location.href}\n\n👤 User tried: ${userInput}\n\n❌ AI widget failed to connect`
          })
        });
      } catch (e) {}
    }

    btn.textContent = 'Diagnose';
    btn.disabled = false;
  });

  // ── Hero form tabs ─────────────────────────────────────────
  document.getElementById('htCallback')?.addEventListener('click', () => {
    document.getElementById('htCallback')!.classList.add('active');
    document.getElementById('htBooking')!.classList.remove('active');
    document.getElementById('hfCallback')!.style.display = 'block';
    document.getElementById('hfBooking')!.style.display = 'none';
  });
  document.getElementById('htBooking')?.addEventListener('click', () => {
    document.getElementById('htBooking')!.classList.add('active');
    document.getElementById('htCallback')!.classList.remove('active');
    document.getElementById('hfBooking')!.style.display = 'block';
    document.getElementById('hfCallback')!.style.display = 'none';
  });

  async function heroSubmit(payload: any, successMsg: string) {
    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      document.getElementById('hfCallback')!.style.display = 'none';
      document.getElementById('hfBooking')!.style.display = 'none';
      document.querySelector('.hero-form-tabs')!.setAttribute('style','display:none');
      document.getElementById('hfSuccessMsg')!.textContent = successMsg;
      document.getElementById('hfSuccess')!.style.display = 'block';
    } catch(e) {
      alert('Network error. Please call (323) 990-7550 directly.');
    }
  }

  document.getElementById('hfSubmitCallback')?.addEventListener('click', async () => {
    const phone = (document.getElementById('hfPhone') as HTMLInputElement).value.trim();
    if (!phone) { alert('Please enter your phone number.'); return; }
    await heroSubmit({ type: 'callback', phone }, "We'll call you back within 15 minutes during business hours.");
  });

  document.getElementById('hfSubmitBooking')?.addEventListener('click', async () => {
    const phone = (document.getElementById('hfBkPhone') as HTMLInputElement).value.trim();
    if (!phone) { alert('Please enter your phone number.'); return; }
    const name = (document.getElementById('hfBkName') as HTMLInputElement).value.trim();
    const address = (document.getElementById('hfBkAddress') as HTMLInputElement).value.trim();
    const time = (document.getElementById('hfBkTime') as HTMLSelectElement).value;
    await heroSubmit({ type: 'booking', phone, name, address, time }, "Booking confirmed! We'll call to confirm your appointment shortly.");
  });
</script>

<script src="/scripts/dryer-idle-animation-v5.js" defer></script>